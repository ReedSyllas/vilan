// Payload sizes: the same values as bare frames and inside the RPC envelopes,
// in both codecs. The §4.1 single-pass envelope writes args/results directly
// into the envelope's serializer, so the envelope overhead is framing only —
// compare the enveloped sizes against the bare values. Sizes are real UTF-8
// byte counts, not code units.

import std::print;
import std::option::Option::{ self, Some, None };
import std::bytes::encode_utf8;
import std::json::{ Json, json_codec };
import std::binary::binary_codec;
import std::wire::{ Wire, Frame, Codec, Serializer, encode };
import std::rpc::{ encode_request, encode_reply, reply };
import pkg::report::section;

[derive(Wire)]
struct BenchTodo {
	id: i32,
	label: str,
	done: bool,
	notes: Option<str>,
}

fun sample_list(count: i32): List<BenchTodo> {
	mut todos: List<BenchTodo> = [];
	mut index = 0;
	for index < count {
		todos.push(BenchTodo {
			id = index,
			label = i"todo item number {index}",
			done = index & 1 == 1,
			notes = if index & 3 == 0 { Some("with a note attached") } else { None },
		});
		index += 1;
	}
	todos
}

fun frame_bytes(frame: Frame): i32 {
	match frame {
		Frame::Text(let text) => encode_utf8(text).len(),
		Frame::Binary(let bytes) => bytes.len(),
	}
}

fun measure(label: str, count: i32) {
	let todos = sample_list(count);
	let bare_json = frame_bytes(encode(json_codec(), todos));
	let bare_binary = frame_bytes(encode(binary_codec(), todos));
	// The request envelope carrying the list as its one argument, and the
	// success reply carrying it as the result — single-pass, both codecs.
	let request_json = frame_bytes(encode_request(json_codec(), "sync", [|s: Serializer| todos.describe(s)]));
	let request_binary = frame_bytes(encode_request(binary_codec(), "sync", [|s: Serializer| todos.describe(s)]));
	let reply_json = frame_bytes(encode_reply(json_codec(), reply(todos)));
	let reply_binary = frame_bytes(encode_reply(binary_codec(), reply(todos)));
	print(i"{label}: bare {bare_json} B json / {bare_binary} B binary; request {request_json} / {request_binary}; reply {reply_json} / {reply_binary}");
}

fun run() {
	section("payload sizes");
	measure("1 todo", 1);
	measure("25 todos", 25);
	measure("200 todos", 200);
}
