// Minimal JWTs, HS512 only (proposal/kolt-migration.md §2.1):
// `base64url(header) . base64url(payload) . base64url(hmac)`. Claims are any
// `Wire` type — `encode_json`/`decode_json` carry the payload, so the claim
// struct is ordinary typed data ([derive(Wire)]), and a malformed or tampered
// token decodes to `None`, never to garbage.

import pkg::base64::{ decode_url, encode_url };
import pkg::bytes::{ Bytes, decode_utf8, encode_utf8 };
import pkg::crypto::{ equals_constant_time, hmac_sha512 };
import pkg::json::{ decode_json, encode_json };
import pkg::option::Option::{ None, Some, self };
import pkg::result::Result::{ Err, Ok, self };
import pkg::wire::Wire;

let header_segment = "eyJhbGciOiJIUzUxMiIsInR5cCI6IkpXVCJ9"; // {"alg":"HS512","typ":"JWT"}

/// Signs `claims` under `secret`, returning the compact token.
async fun sign_hs512<C: Wire>(secret: Bytes, claims: C): str {
	let payload = encode_url(encode_utf8(encode_json(claims)));
	let signing_input = header_segment + "." + payload;
	let signature = hmac_sha512(secret, encode_utf8(signing_input));
	signing_input + "." + encode_url(signature)
}

/// Verifies `token` under `secret`: the signature must match (constant-time)
/// and the payload must decode as `C`. Anything else is `None`.
async fun verify_hs512<C: Wire>(secret: Bytes, token: str): Option<C> {
	let parts = token.split(".");
	if parts.len() != 3 || parts[0] != header_segment {
		None
	} else {
		let expected = hmac_sha512(secret, encode_utf8(parts[0] + "." + parts[1]));
		match decode_url(parts[2]) {
			Some(let given) => {
				if equals_constant_time(expected, given) {
					decode_claims(parts[1])
				} else {
					None
				}
			},
			None => None,
		}
	}
}

/// The payload segment (already signature-verified) decoded as `C`.
fun decode_claims<C: Wire>(segment: str): Option<C> {
	match decode_url(segment) {
		Some(let payload) => {
			let decoded: Result<C, str> = decode_json(decode_utf8(payload));
			match decoded {
				Ok(let claims) => Some(claims),
				Err(let _reason) => None,
			}
		},
		None => None,
	}
}
