
struct Shape {
	type: i32,
	name: str,
	left: str,
	top: str,
	width: str,
	height: str,
}

fun main() {
	let RECTANGLE = 0;
	let CIRCLE = 1;
	let TRIANGLE = 2;
	
	let shape = Shape {
		type = RECTANGLE,
		name = "Rectangle",
		left = 10,
		top = 20,
		width = 70,
		height = 30,
	};
	
	print(shape);
	
	let sum = {
		let a = 10;
		let b = 5;
		a * b
	};
	
	if shape.type == RECTANGLE {
		print("shape is a rectangle");
	}
	
	print(sum);
}
