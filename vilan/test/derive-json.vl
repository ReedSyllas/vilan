import std::print;
import std::result::Result::{ self, Ok, Err };

// `[derive(Json)]` synthesizes both directions — `to_json` (a faithful JSON object
// with real field names, which a bare `JSON.stringify` of a vilan struct can't
// produce) and `from_json` (rebuilding the struct from that object). Scalars
// serialize via the host `JSON.stringify` and are validated on the way back (a
// wrong-typed or missing field is a decode error, so `from_json` yields a
// `Result` — I3); nested derived structs recurse in both directions.
[derive(Json)]
struct Point {
	x: i32,
	y: i32,
}

[derive(Json)]
struct Person {
	name: str,
	age: i32,
	active: bool,
	home: Point,
}

fun main() {
	let p = Point { x = 1, y = 2 };
	print(p.to_json()); // {"x":1,"y":2}

	let person = Person {
		name = "Ada \"A\"",
		age = 36,
		active = true,
		home = Point { x = 3, y = 4 },
	};
	// Escaped string, bool, and a nested object — all faithful.
	let text = person.to_json();
	print(text);

	// `from_json` parses and validates it back into a `Person`; the nested
	// `Point` and every scalar survive, so re-serializing reproduces the
	// original document.
	print(Person::from_json(text) is Ok(let back)
		&& back.to_json() == text // re-serializes identically
		&& back.home.y == 4       // nested field survives
		&& back.name == "Ada \"A\""); // escaped string survives

	// A missing field is a decode error naming the field, not silent garbage.
	print(Person::from_json("{\"name\":\"x\",\"age\":1,\"active\":true}") is Err(let missing));
	print(missing); // missing field home

	// A wrong-typed field is a decode error too.
	print(Person::from_json("{\"name\":5,\"age\":1,\"active\":true,\"home\":{\"x\":0,\"y\":0}}") is Err(let wrong));
	print(wrong); // expected a string
}
