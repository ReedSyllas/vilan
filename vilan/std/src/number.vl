	fun as_i64(self): i64 {
		let widened = self.as_f64();
		label_i64(widened.trunc())
	}

	fun as_u64(self): u64 {
		let widened = self.as_f64();
		label_u64(widened.trunc())
	}

	fun as_f32(self): f32 {
		let widened = self.as_f64();
		label_f32(widened)
	}
}

