import pkg::default::Default;
import pkg::compare::{ PartialEq, Eq, PartialOrd, Ord, Ordering };
import pkg::option::Option::{ self, Some, None };
import pkg::math::PI;
import pkg::operators::{ Add, Sub, Mul, Div, Shl, Shr, BitAnd, BitOr, BitXor };

external struct u32;

impl u32 {
	[extern("Math.pow")]
	external fun pow(self, exponent: u32): u32;

	[extern("Math.min")]
	external fun min(self, other: u32): u32;

	[extern("Math.max")]
	external fun max(self, other: u32): u32;

	fun rem(self, m: u32): u32 {
		self - self / m * m
	}
}

impl u32 with Default {
	fun default(): u32 {
		0u32
	}
}

external struct i32;

impl i32 {
	fun diff(self, other: i32): i32 {
		if self > other {
			self - other
		} else {
			other - self
		}
	}

	// Absolute value, exponentiation, and pairwise min/max — thin wrappers over the
	// host `Math` functions (the receiver is passed as the first argument).
	[extern("Math.abs")]
	external fun abs(self): i32;

	[extern("Math.pow")]
	external fun pow(self, exponent: i32): i32;

	[extern("Math.min")]
	external fun min(self, other: i32): i32;

	[extern("Math.max")]
	external fun max(self, other: i32): i32;

	// Truncated remainder — exact for every integer type (`/` truncates, §F2),
	// the stopgap spelling until the `%` operator lands (backlog H5).
	fun rem(self, m: i32): i32 {
		self - self / m * m
	}
}

impl i32 with Default {
	fun default(): i32 {
		0i32
	}
}

external struct f64;

impl f64 {
	// Floating-point math over the host `Math` functions.
	[extern("Math.abs")]
	external fun abs(self): f64;

	[extern("Math.sqrt")]
	external fun sqrt(self): f64;

	[extern("Math.pow")]
	external fun pow(self, exponent: f64): f64;

	[extern("Math.floor")]
	external fun floor(self): f64;

	[extern("Math.ceil")]
	external fun ceil(self): f64;

	[extern("Math.round")]
	external fun round(self): f64;

	[extern("Math.min")]
	external fun min(self, other: f64): f64;

	[extern("Math.max")]
	external fun max(self, other: f64): f64;

	// --- Trigonometry (radians) ---

	[extern("Math.sin")]
	external fun sin(self): f64;

	[extern("Math.cos")]
	external fun cos(self): f64;

	[extern("Math.tan")]
	external fun tan(self): f64;

	[extern("Math.asin")]
	external fun asin(self): f64;

	[extern("Math.acos")]
	external fun acos(self): f64;

	[extern("Math.atan")]
	external fun atan(self): f64;

	// The two-argument arctangent: `y.atan2(x)` is the angle of the point
	// `(x, y)` — the receiver is `y`, matching the host argument order.
	[extern("Math.atan2")]
	external fun atan2(self, x: f64): f64;

	// --- Exponentials and logarithms ---

	[extern("Math.exp")]
	external fun exp(self): f64;

	// The natural logarithm (the host names it `log`; `ln` avoids the
	// base-ambiguity trap).
	[extern("Math.log")]
	external fun ln(self): f64;

	[extern("Math.log2")]
	external fun log2(self): f64;

	[extern("Math.log10")]
	external fun log10(self): f64;

	[extern("Math.cbrt")]
	external fun cbrt(self): f64;

	// `sqrt(x² + y²)` without intermediate overflow.
	[extern("Math.hypot")]
	external fun hypot(self, other: f64): f64;

	// --- Shape and structure ---

	// `-1`, `0`, or `1` by sign (`-0` and `NaN` pass through, host semantics).
	[extern("Math.sign")]
	external fun sign(self): f64;

	// The fractional part, truncation's complement: `x == x.trunc() + x.fract()`.
	fun fract(self): f64 {
		self - self.trunc()
	}

	// Linear interpolation: `self` at `t == 0`, `to` at `t == 1`.
	fun lerp(self, to: f64, t: f64): f64 {
		self + (to - self) * t
	}

	fun to_radians(self): f64 {
		self * (PI / 180f)
	}

	fun to_degrees(self): f64 {
		self * (180f / PI)
	}

	// Truncated remainder (sign follows the dividend), the method form of `%`.
	fun rem(self, m: f64): f64 {
		self % m
	}

	// --- Classification ---

	// IEEE: NaN is the one value that is not equal to itself.
	fun is_nan(self): bool {
		self != self
	}

	[extern("Number.isFinite")]
	external fun is_finite(self): bool;

	fun is_infinite(self): bool {
		!self.is_finite() && !self.is_nan()
	}
}

impl f64 with Default {
	fun default(): f64 {
		0f
	}
}

external struct BigInt;

impl BigInt with Default {
	fun default(): BigInt {
		0n
	}
}

// --- Ordering impls (backlog K2) — generated once, checked in (this file is
// world-loaded, so it must not dispatch macros). Native `<`/`>` bodies, like
// the `PartialEq` impls above: generic `T: Ord` code accepts the integer
// primitives; the floats are `PartialOrd` ONLY (the stated NaN answer).

impl i32 with Eq {}

impl i32 with PartialOrd {
	fun partial_compare(self, b: i32): Option<Ordering> {
		if self < b {
			Some(Ordering::Less)
		} else {
			if self > b {
				Some(Ordering::Greater)
			} else {
				Some(Ordering::Equal)
			}
		}
	}
}

impl i32 with Ord {
	fun compare(self, b: i32): Ordering {
		if self < b {
			Ordering::Less
		} else {
			if self > b {
				Ordering::Greater
			} else {
				Ordering::Equal
			}
		}
	}
}

