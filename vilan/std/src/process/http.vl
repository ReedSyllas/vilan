// `std::http` — a small HTTP server over `node:http`, exposed through an
// abstract `Server`/`Response` API. The raw `node:http` calls are `[extern]`
// host bindings used internally (and by `std::rpc_server`, which needs partial
// writes for SSE); everything else is ordinary Vilan. This module is pure HTTP —
// protocol mounts (RPC, the connected server) live in `std::rpc_server`.

import pkg::bytes::{ Bytes, new_text_decoder };
import pkg::json::JsonValue;
import pkg::option::Option::{ None, Some, self };

// --- Raw node:http bindings ---

[extern("node:http", "createServer")]
external fun node_create_server(handler: |NodeRequest, NodeResponse| void): NodeServer;

external struct NodeServer;

impl NodeServer {
	[extern(method)]
	external fun listen(self, port: i32, on_ready: || void);

	/// Subscribe to the server's `upgrade` event — a WebSocket handshake
	/// arrives as `(request, raw socket, head)` instead of a normal request.
	[extern(method, "on")]
	external fun on_upgrade(self, event: str, handler: |NodeRequest, NodeSocket, Bytes| void);
}

external struct NodeRequest;

impl NodeRequest {
	[extern(get, "url")]
	external fun url(self): str;

	[extern(get, "method")]
	external fun method(self): str;

	/// The (lowercased) request headers, as an opaque host object — read named
	/// entries with `std::json`'s `JsonValue` accessors (dynamic property access
	/// has no plain extern shape).
	[extern(get, "headers")]
	external fun headers(self): JsonValue;
}

/// A raw TCP socket (`net.Socket`), handed over on a protocol upgrade. Frames
/// are written as bytes; the handshake response is plain text.
external struct NodeSocket;

impl NodeSocket {
	[extern(method, "write")]
	external fun write_text(self, data: str);

	[extern(method, "write")]
	external fun write_bytes(self, data: Bytes);

	/// Inbound chunks (`"data"` — node hands a Buffer, which IS a Uint8Array).
	[extern(method, "on")]
	external fun on_bytes(self, event: str, handler: |Bytes| void);

	/// Lifecycle events with no payload (`"close"`, `"error"`).
	[extern(method, "on")]
	external fun on_signal(self, event: str, handler: || void);

	[extern(method, "destroy")]
	external fun destroy(self);
}

/// Reads a request's full body (a stream) to text. `node:stream/consumers` `text`
/// resolves once the body has fully arrived; for a body-less request it's empty.
[extern("node:stream/consumers", "text")]
async external fun read_request_body(node: NodeRequest): str;

/// The same body as raw bytes (a node `Buffer` IS a Uint8Array) — for frames
/// that may be binary (`std::rpc_server`'s `/rpc`).
[extern("node:stream/consumers", "buffer")]
async external fun read_request_bytes(node: NodeRequest): Bytes;

external struct NodeResponse;

impl NodeResponse {
	[extern(set, "statusCode")]
	external fun set_status_code(self, code: i32);

	[extern(method, "setHeader")]
	external fun set_header_raw(self, name: str, value: str);

	[extern(method, "end")]
	external fun end(self, body: str);

	/// Write a chunk WITHOUT ending the response — a streaming response (SSE).
	/// The host silently drops writes to a destroyed response, so a frame sent
	/// to a just-closed connection is discarded, not an error.
	[extern(method, "write")]
	external fun write(self, chunk: str);

	/// Subscribe to a response stream event (`"close"` fires when the connection
	/// ends — for a never-`end`ed SSE response that means the client went away).
	[extern(method, "on")]
	external fun on_event(self, event: str, callback: || void);

	/// End the response with a binary body (the host accepts a Uint8Array).
	[extern(method, "end")]
	external fun end_bytes(self, body: Bytes);
}

// --- Request ---

struct Request {
	node: NodeRequest,
	content: Bytes,
}

impl Request {
	/// The request target (path + query), e.g. `/client.js`.
	fun path(self): str {
		self.node.url()
	}

	/// The HTTP method, e.g. `GET`.
	fun method(self): str {
		self.node.method()
	}

	/// The full request body as text — empty for a body-less request (e.g. a GET).
	/// Collected eagerly when the request arrives (see `Server::start`).
	fun body(self): str {
		new_text_decoder().decode(self.content)
	}

	/// The same body as raw bytes, for frames that may be binary (an RPC
	/// codec's POST).
	fun bytes(self): Bytes {
		self.content
	}
}

// --- Response ---

struct Response {
	status: i32,
	/// `(name, value)` pairs, written in order. An empty list gets the
	/// default `Content-Type: text/plain`.
	headers: List<(str, str)>,
	body: ResponseBody,
}

/// What a response carries: a buffered text or binary body, or a live
/// STREAM — the closure receives the open stream once the status and
/// headers are written, and the response stays open until closed.
enum ResponseBody {
	Text(str),
	Bytes(Bytes),
	Stream(|ResponseStream| void),
}

/// A live streaming response (SSE and friends): `send` chunks over time;
/// the response stays open until `close` — or until the client goes away
/// (`on_close`). The host silently drops writes to a gone connection, so a
/// chunk sent to a just-closed client is discarded, not an error.
struct ResponseStream {
	node: NodeResponse,
}

impl ResponseStream {
	/// Write one chunk without ending the response.
	fun send(self, chunk: str) {
		self.node.write(chunk);
	}

	/// End the response.
	fun close(self) {
		self.node.end("");
	}

	/// The connection ended (tab closed, network gone) — release
	/// per-connection state here.
	fun on_close(self, handler: || void) {
		self.node.on_event("close", handler);
	}
}

struct ResponseBuilder {
	status: i32,
	headers: List<(str, str)>,
	body: ResponseBody,
}

impl Response {
	fun builder(): ResponseBuilder {
		ResponseBuilder { status = 200, headers = [], body = ResponseBody::Text("") }
	}
}

impl ResponseBuilder {
	fun code(own self, code: i32): ResponseBuilder {
		self.status = code;
		self
	}

	/// Add one header — repeatable; each call appends a `(name, value)` pair.
	fun set_header(own self, name: str, value: str): ResponseBuilder {
		self.headers.push((name, value));
		self
	}

	fun body(own self, body: str): ResponseBuilder {
		self.body = ResponseBody::Text(body);
		self
	}

	/// A binary body.
	fun body_bytes(own self, body: Bytes): ResponseBuilder {
		self.body = ResponseBody::Bytes(body);
		self
	}

	/// A STREAMING response: `on_open` receives the live stream once the
	/// status and headers are written (a suspending `on_open` runs as
	/// spawned work — the response is already open). SSE's shape.
	fun streaming(own self, on_open: |ResponseStream| void): ResponseBuilder {
		self.body = ResponseBody::Stream(on_open);
		self
	}

	fun build(self): Response {
		Response { status = self.status, headers = self.headers, body = self.body }
	}
}

// --- Server ---

struct Server {
	port: i32,
	request_handler: async |Request| Response,
	on_start: |Server| void,
	/// A WebSocket-style protocol upgrade handler, when the app mounted one
	/// (`ServerBuilder::on_upgrade`): `(request, raw socket, head bytes)`.
	upgrade_handler: Option<|NodeRequest, NodeSocket, Bytes| void>,
}

struct ServerBuilder {
	port: i32,
	// Declared `async` (J2's typed channel): the handler may suspend, and
	// `start()` awaits its response before writing.
	request_handler: async |Request| Response,
	on_start: |Server| void,
	on_stop: |Server| void,
	upgrade_handler: Option<|NodeRequest, NodeSocket, Bytes| void>,
}

impl Server {
	fun builder(): ServerBuilder {
		ServerBuilder { port = 3000, request_handler = |request| Response::builder().code(404).body("Not Found").build(), on_start = |server| {}, on_stop = |server| {}, upgrade_handler = None }
	}

	fun url(self): str {
		i"http://localhost:{self.port}/"
	}

	fun start(self) {
		// Adopts asyncness from the `async` field read: the call below
		// awaits the handler's response before writing.
		let request_handler = self.request_handler;
		let on_start = self.on_start;
		let server = self;
		let port = self.port;
		let upgrade_handler = self.upgrade_handler;
		let node_server = node_create_server(|node_request, node_response| {
			// Collect the full request body (as BYTES — it may be binary)
			// before dispatching: the handler is called indirectly and so
			// can't suspend, so it receives the body ready rather than as a
			// stream.
			let content = read_request_bytes(node_request);
			let response = request_handler(Request { node = node_request, content = content });
			node_response.set_status_code(response.status);
			if response.headers.len() == 0 {
				node_response.set_header_raw("Content-Type", "text/plain");
			}
			for header in response.headers {
				let (name, value) = header;
				node_response.set_header_raw(name, value);
			}
			match response.body {
				ResponseBody::Text(let text) => node_response.end(text),
				ResponseBody::Bytes(let bytes) => node_response.end_bytes(bytes),
				// The stream response: status and headers are written; hand
				// the live stream to the app and leave the response open.
				ResponseBody::Stream(let on_open) => on_open(ResponseStream { node = node_response }),
			}
		});
		match upgrade_handler {
			Some(let handler) => node_server.on_upgrade("upgrade", handler),
			None => {},
		}
		node_server.listen(port, || {
			on_start(server);
		});
	}
}

impl ServerBuilder {
	fun port(own self, port: i32): ServerBuilder {
		self.port = port;
		self
	}

	fun on_request(own self, handler: async |Request| Response): ServerBuilder {
		self.request_handler = handler;
		self
	}

	/// Mount a protocol-upgrade handler (a WebSocket handshake arrives here
	/// instead of `on_request`): `(request, raw socket, head bytes)`.
	fun on_upgrade(own self, handler: |NodeRequest, NodeSocket, Bytes| void): ServerBuilder {
		self.upgrade_handler = Some(handler);
		self
	}

	fun on_start(own self, callback: |Server| void): ServerBuilder {
		self.on_start = callback;
		self
	}

	fun on_stop(own self, callback: |Server| void): ServerBuilder {
		self.on_stop = callback;
		self
	}

	fun build(self): Server {
		Server { port = self.port, request_handler = self.request_handler, on_start = self.on_start, upgrade_handler = self.upgrade_handler }
	}
}
