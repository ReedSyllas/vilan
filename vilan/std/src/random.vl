// Random number generation. `range(low, high)` gives a uniformly random value
// in the inclusive range `[low, high]`, for any numeric type.

/// Per-type runtime primitives, lowered to a `Math.random` helper. The `Random`
/// impls below forward to these; prefer `range` over calling them directly.
external fun range_i32(low: i32, high: i32): i32;
external fun range_u32(low: u32, high: u32): u32;
external fun range_f64(low: f64, high: f64): f64;

/// A type that can produce a uniformly random value within an inclusive range.
trait Random {
	fun range(low: Self, high: Self): Self;
}

impl i32 with Random {
	fun range(low: i32, high: i32): i32 {
		range_i32(low, high)
	}
}

impl u32 with Random {
	fun range(low: u32, high: u32): u32 {
		range_u32(low, high)
	}
}

impl f64 with Random {
	fun range(low: f64, high: f64): f64 {
		range_f64(low, high)
	}
}

/// A uniformly random value in the inclusive range `[low, high]`.
fun range<T: Random>(low: T, high: T): T {
	T::range(low, high)
}
