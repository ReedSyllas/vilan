// The RPC runtime (`proposal/transport-rpc.md`): a codec (JSON, via the derives),
// transports (a request/response `Transport` and a full-duplex `DuplexTransport`), and two
// sibling **protocols** over them — `RpcProtocol` (request/response) and the reactive
// protocol (`ReactiveServer`/`ReactiveClient`, pub/sub, §8) — plus the §4.1 foundation
// (`call`, `Dispatcher`, `arg`, `reply`) that `[service(Client)]` generation targets.
//
// Inbound frames are handled in a reactive `batch` — the **wire turn**
// (proposal/reactive-batching.md): signal writes made while dispatching are deferred to the
// turn's flush, so a handler that mutates subscribed state produces ONE coalesced `Update`
// per source alongside its reply.
//
// A note on genericity: `expose` is generic over any `Source<T: Wire>`; the element is
// erased *inside* the runtime to a per-channel starter closure (the capability table holds
// heterogeneous sources, and vilan has no trait objects) that subs the typed source and
// single-passes each value into an `Update` envelope over the wiring-time codec — the wire
// never sees an intermediate encoding. The in-process transports (`LocalTransport`,
// `DuplexEnd`) make everything runnable with no network; real transports mount the same
// protocols.

import pkg::promise::Promise;
import pkg::shared::Shared;
import pkg::option::Option::{ self, Some, None };
import pkg::result::Result::{ self, Ok, Err };
import pkg::json::JsonValue;
import pkg::reactive::{ batch, Source, Signal, Subscription, Disposable };
import pkg::wire::{ Wire, Serializer, Deserializer, Codec, Frame };
import pkg::bytes::{ Bytes, ByteBuffer, bytes_of_buffer, new_text_decoder };
import pkg::fetch::{ get, post, post_bytes };
import pkg::time::{ sleep_for, Duration };

// === Transport: request/response ============================================

// Send an encoded request frame, get the encoded reply. The explicit `Promise` marks the
// round-trip as a place the caller `await`s deliberately. Frames carry either
// format (§6.2) — the codec is chosen at wiring time, not here. A transport
// can FAIL (a dropped socket, an unreachable host) — `Err(reason)` is the
// infrastructure path, mapped to `RpcError::Transport` by `call`
// (proposal/transport-robustness.md §2.4: failure is representable, never a
// dangling promise).
trait Transport {
	fun call(self, request: Frame): Promise<Result<Frame, str>>;
}

// The in-process request/response transport: runs a handler in the same process, wrapped
// as a resolved Promise. `handler` is a protocol's frame handler (an `RpcProtocol`).
struct LocalTransport {
	handler: |Frame| Frame,
}

impl LocalTransport with Transport {
	fun call(self, request: Frame): Promise<Result<Frame, str>> {
		async {
			Ok((self.handler)(request))
		}
	}
}

// === Transport: HTTP ========================================================

// The real request/response transport (§5): POSTs each request frame to the
// endpoint and reads the reply frame from the response body. Works wherever the
// host `fetch` does — browser, node, deno, bun — so it is the default
// client↔server transport. The address is programmatic (Q5): construct it with
// the endpoint URL (`HttpTransport { url = "http://localhost:4000/rpc" }`);
// where the string comes from — hardcoded, env, config — is the app's choice.
// The server side is `std::rpc_server`'s `serve_rpc` / `rpc_response` mount.
struct HttpTransport {
	url: str,
}

impl HttpTransport with Transport {
	// The reply is read in the request's format — both sides run one codec
	// (deployment-wide, Q6), so the kinds always match. (An unreachable host
	// still surfaces as the host fetch's rejection — HTTP-level robustness is
	// recorded beyond-v1; the reconnecting transport is `SocketTransport`.)
	fun call(self, request: Frame): Promise<Result<Frame, str>> {
		async {
			match request {
				Frame::Text(let body) => {
					let response = post(self.url, body).send();
					Ok(Frame::Text(response.text()))
				},
				Frame::Binary(let body) => {
					let response = post_bytes(self.url, body);
					Ok(Frame::Binary(response.bytes()))
				},
			}
		}
	}
}

// === Transport: full-duplex =================================================

// A dumb, bidirectional frame pipe: either end may `send` at any time, so the server can
// push unprompted (§5). This is the shape the reactive protocol needs. Frames carry either
// format (§6.2) — a text-only transport (`SplitDuplex`) rejects binary loudly.
trait DuplexTransport {
	fun send(self, frame: Frame);
	fun on_frame(self, handler: |Frame| void);
}

// The in-process duplex end: a settable inbound-handler slot (`me`) and the peer's slot
// (`peer`) that our `send` fires into. Two cross-linked ends (`duplex_pair`) form one
// connection. `Shared` makes each slot one cell shared by both ends.
struct DuplexEnd {
	peer: Shared<Option<|Frame| void>>,
	me: Shared<Option<|Frame| void>>,
}

impl DuplexEnd with DuplexTransport {
	fun send(self, frame: Frame) {
		match self.peer.read() {
			Some(let handler) => handler(frame),
			None => {},
		}
	}

	fun on_frame(self, handler: |Frame| void) {
		self.me.write() = Some(handler);
	}
}

// Create two connected duplex ends: whatever one sends arrives at the other's handler.
fun duplex_pair(): (DuplexEnd, DuplexEnd) {
	let slot_a: Shared<Option<|Frame| void>> = Shared::new(None);
	let slot_b: Shared<Option<|Frame| void>> = Shared::new(None);
	let a = DuplexEnd { peer = slot_b, me = slot_a };
	let b = DuplexEnd { peer = slot_a, me = slot_b };
	(a, b)
}

// Bridge an in-process `DuplexEnd` to any real `DuplexTransport`: frames flow both
// ways. The reactive runtime (`ReactiveServer`/`ReactiveClient`) holds a concrete
// `DuplexEnd`, so this is how it rides a real wire (`SplitDuplex`, a future
// WebSocket) unchanged: hand it `bridge(wire)`.
fun bridge<Tx: DuplexTransport>(wire: Tx): DuplexEnd {
	let (inner, outer) = duplex_pair();
	outer.on_frame(|frame| wire.send(frame));
	wire.on_frame(|frame| outer.send(frame));
	inner
}

// === Transport: SSE + POST (SplitDuplex) ====================================

// The real duplex transport over plain HTTP (§5's fallback, no WebSocket needed):
// server→client frames arrive on a long-lived SSE stream (`GET {base}/events`),
// and client→server frames POST to `{base}/send?c=<connection>`. The server side
// is `std::rpc_server`'s `serve_connected`; open one with `connect_split(base_url)`.
// A true WebSocket transport becomes a drop-in sibling once it lands.
struct SplitDuplex {
	// The connection id the server announced — apps use it to correlate this
	// duplex connection with RPC calls (e.g. an `attach(connection)` method).
	connection: i32,
	send_url: str,
	inbound: Shared<Option<|Frame| void>>,
	// Frames that arrived before `on_frame` was set (e.g. pushed by the server
	// during the handshake) — queued, then flushed to the first handler.
	early: Shared<List<Frame>>,
}

impl SplitDuplex with DuplexTransport {
	// Fire-and-forget POST. Ordering across rapid sends is not guaranteed
	// (separate requests); the reactive protocol's client→server traffic
	// (subscribe/unsubscribe) is insensitive to it.
	fun send(self, frame: Frame) {
		match frame {
			Frame::Text(let body) => {
				let _ = post(self.send_url, body).send();
			},
			// SSE (the server→client leg) is text-only forever, so this
			// transport is too: a binary codec over it is a wiring error, and
			// the first Subscribe trips it loudly right here.
			Frame::Binary(let _bytes) => {
				panic("SplitDuplex is text-only (SSE); use connect_socket for a binary codec");
			},
		}
	}

	fun on_frame(self, handler: |Frame| void) {
		self.inbound.write() = Some(handler);
		for frame in self.early.read() {
			handler(frame);
		}
		self.early.write() = [];
	}
}

// Split complete SSE events off `buffer`, dispatching each `data:` payload, and
// return the incomplete remainder (an event ends at a blank line).
fun drain_sse(buffer: str, dispatch: |str| void): str {
	let parts = buffer.split("\n\n");
	mut remainder = "";
	mut index = 0;
	for part in parts {
		if index == parts.len() - 1 {
			remainder = part;
		} else {
			for line in part.split("\n") {
				if line.starts_with("data: ") {
					dispatch(line.substring(6, line.len()));
				}
			}
		}
		index += 1;
	}
	remainder
}

// Open a SplitDuplex connection to `base_url` (e.g. `http://localhost:4000`):
// waits for the server's connection announcement (`__conn:<id>`, the stream's
// first event), then keeps pumping inbound events to the transport's handler in
// the background for the connection's lifetime.
fun connect_split(base_url: str): SplitDuplex {
	let response = get(i"{base_url}/events").send();
	let reader = response.body_stream().reader();
	let decoder = new_text_decoder();
	let inbound: Shared<Option<|Frame| void>> = Shared::new(None);
	let early: Shared<List<Frame>> = Shared::new([]);
	let connection: Shared<str> = Shared::new("");
	// Route one inbound frame (SSE delivers text, so it arrives as `Frame::Text`):
	// the handler if one is set, else the early queue (flushed to the first
	// handler by `on_frame`).
	let dispatch = |payload: str| {
		match inbound.read() {
			Some(let handler) => handler(Frame::Text(payload)),
			None => early.write().push(Frame::Text(payload)),
		}
	};
	mut buffer = "";
	for connection.read() == "" {
		let chunk = reader.read_chunk();
		if chunk.finished() {
			jump break;
		}
		buffer += decoder.decode(chunk.payload());
		buffer = drain_sse(buffer, |frame| {
			if frame.starts_with("__conn:") {
				connection.write() = frame.substring(7, frame.len());
			} else {
				dispatch(frame);
			}
		});
	}
	// Pump the rest of the stream for the connection's lifetime.
	let leftover = buffer;
	let _ = async {
		mut rest = leftover;
		for {
			let chunk = reader.read_chunk();
			if chunk.finished() {
				jump break;
			}
			rest += decoder.decode(chunk.payload());
			rest = drain_sse(rest, dispatch);
		}
	};
	SplitDuplex {
		connection = parse_announced(connection.read()),
		send_url = i"{base_url}/send?c={connection.read()}",
		inbound,
		early,
	}
}

// The `__conn:<id>` announcement's id, parsed once at connect time. A
// non-numeric announcement is a broken server — refuse loudly.
fun parse_announced(text: str): i32 {
	match text.parse_i32() {
		Some(let id) => id,
		None => {
			panic("malformed connection announcement: " + text);
			0 - 1 // unreachable — the panic throws
		},
	}
}

// === Transport: WebSocket (SocketDuplex) ====================================

// The host `WebSocket` class — browser, node (22+), deno, and bun all provide
// it globally, framing included; only the SERVER half needs `std::ws`.
external struct WebSocket;

[extern(new, "WebSocket")]
external fun new_web_socket(url: str): WebSocket;

external struct SocketMessage;

impl SocketMessage {
	[extern(get, "data")]
	external fun data(self): str;

	// The same `data` untyped — for the text/binary discrimination below.
	[extern(get, "data")]
	external fun data_value(self): JsonValue;

	// The same `data` as the raw buffer — valid only when the message IS
	// binary (`binaryType = "arraybuffer"` makes binary messages ArrayBuffers).
	[extern(get, "data")]
	external fun data_buffer(self): ByteBuffer;
}

// The one host-level type oracle: `Object.prototype.toString.call(x)` names any
// value's class — `"[object String]"` vs `"[object ArrayBuffer]"` is how an
// inbound socket message picks its lane.
[extern("Object.prototype.toString.call")]
external fun host_kind(value: JsonValue): str;

impl WebSocket {
	[extern(method, "send")]
	external fun transmit(self, data: str);

	// The same host `send` — WebSocket accepts bytes directly.
	[extern(method, "send")]
	external fun transmit_bytes(self, data: Bytes);

	// Make binary messages arrive as ArrayBuffers (the default is Blob).
	[extern(set, "binaryType")]
	external fun set_binary_type(self, kind: str);

	[extern(set, "onmessage")]
	external fun set_on_message(self, handler: |SocketMessage| void);

	// Failure events — a dial that never opens, or a live connection dropping.
	[extern(set, "onclose")]
	external fun set_on_close(self, handler: || void);

	[extern(set, "onerror")]
	external fun set_on_error(self, handler: || void);

	[extern(method, "close")]
	external fun close(self);
}

// One dial attempt's outcome channel: `finish(true)` when the `__conn`
// announcement lands, `finish(false)` on close/error first. (A host Promise
// resolves first-call-wins, so a close after the announcement is inert.)
[extern(new, "Promise")]
external fun dial_promise(executor: |(|bool| void)| void): Promise<bool>;

// The connection lifecycle, as a signal a UI can bind ("reconnecting…") —
// Railway's `isReady`, typed (proposal/transport-robustness.md §2.1).
// `Closed` is terminal: the retry budget ran out (or the server's contract
// drifted); the app decides what a fresh start looks like.
[derive(PartialEq, Debug)]
enum ConnectionState {
	Connected,
	Reconnecting,
	Closed,
}

// A pending RPC call multiplexed on the socket: its correlation id and the
// resolver its reply completes — with `Err` for a connection lost while the
// call was in flight (proposal/transport-robustness.md §2.4: rejected, never
// dangling).
struct PendingCall {
	request: i32,
	complete: |Result<Frame, str>| void,
}

// The socket's binary channel tags (§5's multiplex, byte form): a binary WS
// message is `0x64` ('d') + a duplex frame, or `0x72` ('r') + a 4-byte LE
// request id + an RPC frame — the byte mirror of the `d:`/`r:<id>:` text
// prefixes, shared verbatim with `serve_connected`'s upgrade path.
fun tag_duplex_bytes(payload: Bytes): Bytes {
	let tag = Bytes::alloc(1);
	tag.set(0, 0x64);
	Bytes::concat(tag, payload)
}

fun tag_rpc_bytes(request: i32, payload: Bytes): Bytes {
	let header = Bytes::alloc(5);
	header.set(0, 0x72);
	header.set(1, request);
	header.set(2, request >> 8);
	header.set(3, request >> 16);
	header.set(4, request >> 24);
	Bytes::concat(header, payload)
}

// The true duplex transport (§5): one WebSocket carrying BOTH protocols and
// BOTH frame kinds — text messages use the `d:<frame>`/`r:<id>:<frame>`
// prefixes, binary messages the tag bytes above. The server side is
// `serve_connected`'s upgrade path; open one with `connect_socket(url)` — the
// drop-in swap for `connect_split`, same `__conn:<id>` handshake, same
// `.connection` for RPC correlation.
//
// The duplex SURVIVES a dropped connection (proposal/transport-robustness.md
// §2.2): everything downstream — `bridge`, `ReactiveClient`, `SocketTransport`,
// a generated client — holds this same value across reconnects, and the
// reconnect loop swaps the `Shared` cells inside it.
struct SocketDuplex {
	socket: Shared<WebSocket>,
	// The address to redial.
	url: str,
	// The connection id the server announced — correlates this duplex with
	// RPC calls (e.g. an `attach(connection)` method), like `SplitDuplex`.
	// A cell: every reconnect lands a fresh id.
	connection: Shared<i32>,
	state: Signal<ConnectionState>,
	inbound: Shared<Option<|Frame| void>>,
	// Frames that arrived before `on_frame` was set — queued, then flushed.
	early: Shared<List<Frame>>,
	pending: Shared<List<PendingCall>>,
	next_request: Shared<i32>,
	// Run (and awaited, in order) after each successful re-dial — the
	// generated client re-attaches its mirrors here. Stored plain (an `async`
	// closure TYPE lives only at parameter/`let` seams, J2 v1); the runner
	// re-marks each entry at a `let` so the calls await.
	on_reconnect: Shared<List<|| void>>,
}

impl SocketDuplex with DuplexTransport {
	// While not connected, control frames DROP: a `Subscribe` is re-sent by
	// the reconnect's rebind, and RPC frames never reach here (fail-fast in
	// `SocketTransport.call`).
	fun send(self, frame: Frame) {
		if self.state.get() == ConnectionState::Connected {
			match frame {
				Frame::Text(let body) => self.socket.read().transmit("d:" + body),
				Frame::Binary(let bytes) => self.socket.read().transmit_bytes(tag_duplex_bytes(bytes)),
			}
		}
	}

	fun on_frame(self, handler: |Frame| void) {
		self.inbound.write() = Some(handler);
		for frame in self.early.read() {
			handler(frame);
		}
		self.early.write() = [];
	}
}

impl SocketDuplex {
	// The RPC half of the multiplex: a `Transport` over this same socket, so
	// calls ride the open connection instead of HTTP requests beside it.
	fun transport(self): SocketTransport {
		SocketTransport { duplex = self }
	}

	// Reject every in-flight call — a dropped connection can never deliver
	// their replies (the reply may exist server-side; the CALLER decides
	// whether a retry is safe — §2.4, never a blind re-send).
	fun reject_pending(self, reason: str) {
		for call in self.pending.read() {
			(call.complete)(Err(reason));
		}
		self.pending.write() = [];
	}
}

// A correlated reply arrived: complete and forget its pending call.
fun settle_pending(pending: Shared<List<PendingCall>>, request: i32, reply: Frame) {
	mut kept: List<PendingCall> = [];
	for call in pending.read() {
		if call.request == request {
			(call.complete)(Ok(reply));
		} else {
			kept.push(call);
		}
	}
	pending.write() = kept;
}

// Route one duplex frame to the handler, or the early queue before one is set.
fun deliver_inbound(
	inbound: Shared<Option<|Frame| void>>,
	early: Shared<List<Frame>>,
	payload: Frame,
) {
	match inbound.read() {
		Some(let handler) => handler(payload),
		None => early.write().push(payload),
	}
}

// `reply_promise`'s resolver carries the reply frame — or the transport
// failure that means it will never come.
[extern(new, "Promise")]
external fun reply_promise(executor: |(|Result<Frame, str>| void)| void): Promise<Result<Frame, str>>;

// One socket, `impl Transport`: each call rides the multiplex in the request
// frame's own kind — text as `r:<id>:<frame>`, binary as the tagged-byte form
// — and resolves when the reply with the same id lands. Not connected =
// fail fast (Railway's rule, typed): the caller gets
// `Err(RpcError::Transport("not connected"))` immediately.
struct SocketTransport {
	duplex: SocketDuplex,
}

impl SocketTransport with Transport {
	fun call(self, request: Frame): Promise<Result<Frame, str>> {
		async {
			if self.duplex.state.get() == ConnectionState::Connected {
				let id = self.duplex.next_request.read();
				self.duplex.next_request.write() = id + 1;
				await reply_promise(|complete: |Result<Frame, str>| void| {
					self.duplex.pending.write().push(PendingCall { request = id, complete });
					match request {
						Frame::Text(let body) => self.duplex.socket.read().transmit(i"r:{id}:{body}"),
						Frame::Binary(let bytes) => self.duplex.socket.read().transmit_bytes(tag_rpc_bytes(id, bytes)),
					}
				})
			} else {
				Err("not connected")
			}
		}
	}
}

impl SocketTransport {
	// The duplex's lifecycle, for the UI — bind it ("reconnecting…") or gate
	// optimistic writes on it.
	fun connection_state(self): Signal<ConnectionState> {
		self.duplex.state
	}
}

// Route one inbound TEXT socket message by its channel prefix. `r:<id>:<frame>`
// settles the pending call; `d:<frame>` goes to the duplex handler (or the
// early queue); anything else is ignored (forward compatibility).
fun route_socket_frame(
	frame: str,
	pending_settle: |i32, Frame| void,
	dispatch: |Frame| void,
) {
	if frame.starts_with("r:") {
		let rest = frame.substring(2, frame.len());
		let parts = rest.split(":");
		let id_text = parts[0];
		let reply = rest.substring(id_text.len() + 1, rest.len());
		match id_text.parse_i32() {
			Some(let request) => pending_settle(request, Frame::Text(reply)),
			None => {},
		}
	} else if frame.starts_with("d:") {
		dispatch(Frame::Text(frame.substring(2, frame.len())));
	}
}

// Route one inbound BINARY socket message by its tag byte — the byte mirror of
// `route_socket_frame`. An unknown tag is ignored (forward compatibility).
fun route_socket_bytes(
	message: Bytes,
	pending_settle: |i32, Frame| void,
	dispatch: |Frame| void,
) {
	if message.len() == 0 {
		ret;
	}
	let tag = message.get(0);
	if tag == 0x72 && message.len() >= 5 {
		let request = message.get(1)
			| message.get(2) << 8
			| message.get(3) << 16
			| message.get(4) << 24;
		pending_settle(request, Frame::Binary(message.slice(5, message.len())));
	} else if tag == 0x64 {
		dispatch(Frame::Binary(message.slice(1, message.len())));
	}
}

// One dial attempt: a fresh socket, fully wired for the steady state (the
// routing closures come from the duplex's shared cells, so replies and duplex
// frames land in the SAME places across reconnects). Resolves `Ok((socket,
// connection))` when the `__conn:<id>` announcement arrives, `Err` when the
// socket closes or errors first (an unreachable server).
fun dial(
	url: str,
	settle: |i32, Frame| void,
	dispatch: |Frame| void,
): Result<(WebSocket, i32), str> {
	let socket = new_web_socket(url);
	socket.set_binary_type("arraybuffer");
	let connection: Shared<str> = Shared::new("");
	let opened = await dial_promise(|finish: |bool| void| {
		socket.set_on_close(|| finish(false));
		socket.set_on_error(|| finish(false));
		socket.set_on_message(|message| {
			if host_kind(message.data_value()) == "[object ArrayBuffer]" {
				route_socket_bytes(bytes_of_buffer(message.data_buffer()), settle, dispatch);
				ret;
			}
			let frame = message.data();
			if connection.read() == "" && frame.starts_with("__conn:") {
				connection.write() = frame.substring(7, frame.len());
				finish(true);
			} else {
				route_socket_frame(frame, settle, dispatch);
			}
		});
	});
	if opened {
		Ok((socket, parse_announced(connection.read())))
	} else {
		Err(i"could not reach {url}")
	}
}

// Dial until it opens or the budget runs out (proposal/transport-robustness.md
// §2.3): 10 attempts, doubling from 250ms and capped at 4s — fast for the
// blip, capped pressure for the outage. Railway's attempt budget, better
// curve. The first attempt is immediate.
fun dial_with_backoff(
	url: str,
	settle: |i32, Frame| void,
	dispatch: |Frame| void,
): Result<(WebSocket, i32), str> {
	mut outcome: Result<(WebSocket, i32), str> = Err(i"could not reach {url}");
	mut attempt = 0;
	mut delay = 250i64;
	for attempt < 10 {
		if attempt > 0 {
			sleep_for(Duration::millis(delay));
			delay = if delay * 2i64 > 4000i64 { 4000i64 } else { delay * 2i64 };
		}
		outcome = dial(url, settle, dispatch);
		if outcome is Ok(let _opened) {
			jump break;
		}
		attempt += 1;
	}
	outcome
}

// Arm the CURRENT socket's failure events: a close or error on the live
// connection begins the reconnect loop. (Dial-time failures are the dial's
// own `finish(false)` — this takes over only after a successful handshake.)
fun watch_socket(duplex: SocketDuplex) {
	let socket = duplex.socket.read();
	socket.set_on_close(|| handle_drop(duplex));
	socket.set_on_error(|| handle_drop(duplex));
}

// The connection dropped: reject the in-flight calls, then redial with
// backoff. On success the duplex's cells swap to the fresh socket/connection,
// the state flips back to `Connected` (so the re-attach hooks can CALL), and
// the hooks run — awaited, in order. On a spent budget the duplex closes for
// good. `error` then `close` (or a stale event from a replaced socket) finds
// the state already advanced and stops at the guard.
fun handle_drop(duplex: SocketDuplex) {
	if duplex.state.get() == ConnectionState::Connected {
		duplex.state.set(ConnectionState::Reconnecting);
		duplex.reject_pending("connection lost");
		let pending = duplex.pending;
		let inbound = duplex.inbound;
		let early = duplex.early;
		let settle = |request: i32, reply: Frame| settle_pending(pending, request, reply);
		let dispatch = |payload: Frame| deliver_inbound(inbound, early, payload);
		match dial_with_backoff(duplex.url, settle, dispatch) {
			Ok(let opened) => {
				let (socket, connection) = opened;
				duplex.socket.write() = socket;
				duplex.connection.write() = connection;
				watch_socket(duplex);
				duplex.state.set(ConnectionState::Connected);
				for entry in duplex.on_reconnect.read() {
					// Re-marked at the `let` so the call awaits (J2's typed
					// channel): re-attach completes before the next hook.
					let hook: async || void = entry;
					hook();
				}
			},
			Err(let _reason) => duplex.state.set(ConnectionState::Closed),
		}
	}
}

// Open a WebSocket connection to `url` (e.g. `ws://localhost:4000`): resolves
// once the server's `__conn:<id>` announcement lands (which also proves the
// socket is open — sends are safe after this returns). Dials with the same
// backoff as a reconnect, so a briefly-unavailable server delays the start
// instead of failing it; a server that stays away returns `Err`.
fun connect_socket(url: str): Result<SocketDuplex, str> {
	let inbound: Shared<Option<|Frame| void>> = Shared::new(None);
	let early: Shared<List<Frame>> = Shared::new([]);
	let pending: Shared<List<PendingCall>> = Shared::new([]);
	let settle = |request: i32, reply: Frame| settle_pending(pending, request, reply);
	let dispatch = |payload: Frame| deliver_inbound(inbound, early, payload);
	match dial_with_backoff(url, settle, dispatch) {
		Err(let reason) => Err(reason),
		Ok(let opened) => {
			let (socket, connection) = opened;
			let duplex = SocketDuplex {
				socket = Shared::new(socket),
				url,
				connection = Shared::new(connection),
				state = Signal::new(ConnectionState::Connected),
				inbound,
				early,
				pending,
				next_request = Shared::new(0),
				on_reconnect = Shared::new([]),
			};
			watch_socket(duplex);
			Ok(duplex)
		},
	}
}

// === Wire envelope (RPC) ====================================================

// The request handle a dispatcher hands to handlers: the method that routed it
// plus the request's deserializer, positioned at the first argument. `arg`
// pulls the NEXT argument — arguments are read in declaration order, exactly
// once (the schema-ordered binary format requires it; generated handlers obey
// by construction, hand-written ones by contract — proposal §4.1).
struct RpcRequest {
	method: str,
	deserializer: Deserializer,
	arity: i32,
}

// What a handler returns: a result that describes itself into the reply
// envelope (single-pass — no intermediate encoding), or a failure.
enum RpcOutcome {
	Success(|Serializer| void),
	Failure(RpcError),
}

// An infrastructure-level failure — distinct from an application error, which is part of
// a procedure's own return type (e.g. `Option<User>` for "might not exist").
[derive(Wire, Debug)]
enum RpcError {
	Transport(str),
	Decode(str),
	Remote(str),
	// The connect-time contract check refused a drifted server (Q6): the two
	// sides were built against different service surfaces.
	Contract(str),
	Unauthorized,
}

// --- Envelope encode/decode (shared by `call`, the protocol, and benchmarks) --

// One request envelope, written in a single pass: the method, then each
// argument described straight into the same serializer. On the JSON codec the
// args are plain values (`{"method":"add","args":[1]}` — no escaping).
fun encode_request(codec: Codec, method: str, args: List<|Serializer| void>): Frame {
	let (serializer, finish) = (codec.writer)();
	(serializer.begin_struct)(2);
	(serializer.field)("method");
	(serializer.str_value)(method);
	(serializer.field)("args");
	(serializer.begin_list)(args.len());
	for describe in args {
		describe(serializer);
	}
	(serializer.end_list)();
	(serializer.end_struct)();
	finish()
}

// Open a request frame into the handle handlers consume. A corrupt frame
// leaves the deserializer poisoned; the protocol turns that into a `Decode`
// failure before routing.
fun open_request(codec: Codec, frame: Frame): RpcRequest {
	let deserializer = (codec.reader)(frame);
	(deserializer.begin_struct)();
	(deserializer.field)("method");
	let method = (deserializer.str_value)();
	(deserializer.field)("args");
	let arity = (deserializer.begin_list)();
	RpcRequest { method = method, deserializer = deserializer, arity = arity }
}

// One reply envelope: an externally-tagged `Success` carrying the described
// result, or `Failure` carrying the `RpcError`.
fun encode_reply(codec: Codec, outcome: RpcOutcome): Frame {
	let (serializer, finish) = (codec.writer)();
	match outcome {
		RpcOutcome::Success(let describe) => {
			(serializer.begin_variant)("Success", 1);
			describe(serializer);
			(serializer.end_variant)();
		},
		RpcOutcome::Failure(let error) => {
			(serializer.begin_variant)("Failure", 1);
			error.describe(serializer);
			(serializer.end_variant)();
		},
	}
	finish()
}

// === RpcProtocol ============================================================

// The request/response protocol over one codec: open the request envelope,
// route through the application `dispatch`, encode the outcome. It always
// replies — an unknown method or a corrupt frame is a `Failure` envelope, not
// silence. `[service(Client)]` generation emits the dispatch routing;
// `Dispatcher` below is the hand-written form.
struct RpcProtocol {
	codec: Codec,
	dispatch: |RpcRequest| RpcOutcome,
}

impl RpcProtocol {
	fun respond(self, frame: Frame): Frame {
		let request = open_request(self.codec, frame);
		let outcome = match (request.deserializer.failed)() {
			Some(let reason) => RpcOutcome::Failure(RpcError::Decode(reason)),
			None => (self.dispatch)(request),
		};
		encode_reply(self.codec, outcome)
	}
}

// A `LocalTransport` that routes every request through an `RpcProtocol` — the in-process
// wiring of a client stub to its server dispatcher. The handler runs in a `batch` — the
// **wire turn** (proposal/reactive-batching.md): signal writes made while dispatching are
// deferred to the turn's flush, so a method that mutates subscribed state produces ONE
// coalesced `Update` per source alongside its reply, not one per write.
fun local_rpc(protocol: RpcProtocol): LocalTransport {
	LocalTransport {
		handler = |frame| batch(|| protocol.respond(frame)),
	}
}

// === Foundation: the ergonomic client + server API (proposal §4.1) ==========
//
// `call<T>` collapses a client round-trip (envelope -> await -> decode) into one line;
// `Dispatcher` routes requests to typed handlers, `arg`/`reply` pulling and
// describing values through the wiring-time codec (§6.2) — single-pass, no
// intermediate encoding.
// This is the foundation `[service(Client)]` generation emits over — and the API to use
// directly when writing the plumbing by hand.

// One over-the-wire call: encode the request in a single pass (each argument
// describes itself into the envelope's serializer), await the round-trip, and
// decode the reply as `T` (inferred from the call site). Infrastructure
// failures — transport, decode, a remote error — surface as `Err(RpcError)`.
fun call<T: Wire, Tx: Transport>(
	transport: Tx,
	codec: Codec,
	method: str,
	args: List<|Serializer| void>,
): Result<T, RpcError> {
	let outcome = await transport.call(encode_request(codec, method, args));
	match outcome {
		// The transport itself failed — a dropped connection, an unreachable
		// host, a call issued while disconnected.
		Err(let reason) => Err(RpcError::Transport(reason)),
		Ok(let reply_frame) => {
			let deserializer = (codec.reader)(reply_frame);
			let tag = (deserializer.variant_tag)();
			match tag {
				"Success" => {
					(deserializer.begin_variant)("Success", 1);
					let value: T = T::rebuild(deserializer);
					match (deserializer.failed)() {
						None => Ok(value),
						Some(let reason) => Err(RpcError::Decode(reason)),
					}
				},
				"Failure" => {
					(deserializer.begin_variant)("Failure", 1);
					let error: RpcError = RpcError::rebuild(deserializer);
					(deserializer.end_variant)();
					Err(error)
				},
				_ => Err(RpcError::Decode("unrecognized reply envelope")),
			}
		},
	}
}

// Pull the NEXT argument at the parameter's type (`index` documents the
// position at the call site — reads are positional and once-each; see
// `RpcRequest`). A missing/garbled argument poisons the request's
// deserializer; check `decode_failed` before running the impl.
fun arg<T: Wire>(request: RpcRequest, index: i32): T {
	T::rebuild(request.deserializer)
}

// Whether decoding this request has failed so far — the gate between the
// `arg` pulls and the impl call, turning a garbled request into a clean
// `RpcError::Decode` instead of an impl run on zero values.
fun decode_failed(request: RpcRequest): Option<str> {
	(request.deserializer.failed)()
}

// Capture a procedure's result as a success outcome — described into the
// reply envelope when the protocol encodes it.
fun reply<T: Wire>(value: T): RpcOutcome {
	RpcOutcome::Success(|serializer: Serializer| value.describe(serializer))
}

// One route: a method name and the handler that consumes the request handle
// and produces an outcome.
struct Route {
	method: str,
	handler: |RpcRequest| RpcOutcome,
}

// The server router: register handlers by method name, then route each request to its match
// (or an `unknown method` failure). `into_protocol` wraps it as an `RpcProtocol` for a transport.
struct Dispatcher {
	routes: Shared<List<Route>>,
}

impl Dispatcher {
	fun new(): Dispatcher {
		Dispatcher { routes = Shared::new([]) }
	}

	// Register a handler for a method name, returning `self` so registrations chain.
	fun on(self, method: str, handler: |RpcRequest| RpcOutcome): Dispatcher {
		self.routes.write().push(Route { method, handler });
		self
	}

	// Route a request to its handler, or fail with `unknown method`.
	fun handle(self, request: RpcRequest): RpcOutcome {
		match self.routes.read().filter(|route| route.method == request.method).first() {
			Some(let route) => (route.handler)(request),
			None => RpcOutcome::Failure(RpcError::Remote("unknown method: " + request.method)),
		}
	}

	// Wrap as an `RpcProtocol` over `codec` — the wiring-time format choice
	// (§6.2) — ready to mount on a transport (e.g. `local_rpc`).
	fun into_protocol(self, codec: Codec): RpcProtocol {
		RpcProtocol { codec = codec, dispatch = |request| self.handle(request) }
	}
}

// === Reactive protocol ======================================================

// The protocol's frames — `Subscribe(channel)` / `Unsubscribe(channel)` up,
// `Update(channel, value)` down — are written *single-pass* over the codec,
// like RPC's envelopes: an update's value describes itself straight into the
// envelope's serializer, so the wire never sees an intermediate encoding
// (proposal §8, the codec upgrade).

// One control frame: the client→server half.
fun encode_control(codec: Codec, kind: str, channel: i32): Frame {
	let (serializer, finish) = (codec.writer)();
	(serializer.begin_variant)(kind, 1);
	(serializer.i32_value)(channel);
	(serializer.end_variant)();
	finish()
}

// One update frame: the channel, then the value described inline.
fun encode_update(codec: Codec, channel: i32, describe: |Serializer| void): Frame {
	let (serializer, finish) = (codec.writer)();
	(serializer.begin_variant)("Update", 2);
	(serializer.i32_value)(channel);
	describe(serializer);
	(serializer.end_variant)();
	finish()
}

// --- The session registry (Client::connect's server half, §4.2) -------------

// Per-connection reactive sessions, keyed by connection id — what the
// generated `__attach` route answers from. `serve_service` populates it on
// connect and disposes on disconnect; apps wanting custom per-connection
// state keep the manual pattern (`serve_connected` + their own registry).
let reactive_sessions: Shared<List<(i32, ReactiveServer)>> = Shared::new([]);

// Adopt a fresh connection: one reactive session on its wire, speaking the
// protocol's codec (§6.2 — one codec deployment-wide, Q6).
fun register_session(connection: i32, wire: DuplexEnd, codec: Codec) {
	reactive_sessions.write().push((connection, ReactiveServer::new(wire, codec)));
}

// The connection closed: dispose its session so signal changes stop fanning
// out to (or retaining) the dead wire.
fun drop_session(connection: i32) {
	mut kept: List<(i32, ReactiveServer)> = [];
	for entry in reactive_sessions.read() {
		let (id, session) = entry;
		if id == connection {
			session.dispose();
		} else {
			kept.push((id, session));
		}
	}
	reactive_sessions.write() = kept;
}

// The live session for a connection, if it is still connected.
fun session_of(connection: i32): Option<ReactiveServer> {
	for entry in reactive_sessions.read() {
		let (id, session) = entry;
		if id == connection {
			ret Some(session);
		}
	}
	None
}

// Channel ids — module-level, one counter for the program (mirrors reactive's
// `next_subscriber_id`).
let next_channel: Shared<i32> = Shared::new(0);

fun fresh_channel(): i32 {
	let id = next_channel.read();
	next_channel.write() = id + 1;
	id
}

// --- Server side: the capability table --------------------------------------

// The reactive protocol's server half: a per-connection **capability table**
// mapping a channel id to a *starter* for the exposed source, plus the live
// forwards started by client subscriptions. A `Signal`/`Source` never crosses
// as a value — it is exported as an id, and its updates flow as `Update`
// frames (proposal §8).
struct ReactiveServer {
	transport: DuplexEnd,
	codec: Codec,
	// Per channel, the starter that subs the typed source and forwards each
	// value as an `Update` frame. Nothing subscribes — or is retained — until
	// a client asks.
	sources: Shared<List<(i32, || Subscription)>>,
	live: Shared<List<(i32, Subscription)>>,
}

impl ReactiveServer {
	fun new(transport: DuplexEnd, codec: Codec): ReactiveServer {
		let server = ReactiveServer {
			transport,
			codec,
			sources = Shared::new([]),
			live = Shared::new([]),
		};
		(server.transport).on_frame(|frame| {
			// every inbound frame is handled in a turn (proposal/reactive-batching.md)
			batch(|| server.receive(frame));
		});
		server
	}

	// Export a `Source<T>` under a fresh channel id; the id is what crosses the
	// wire in place of the source. `T` is erased *here*, inside the runtime, to
	// the starter closure (the capability table holds heterogeneous sources):
	// on a client's Subscribe it subs the typed source and single-passes each
	// value straight into an `Update` envelope over the wiring-time codec.
	fun expose<T: Wire, S: Source<T>>(self, source: S): i32 {
		let channel = fresh_channel();
		let transport = self.transport;
		let codec = self.codec;
		let starter = || source.sub(|value| {
			transport.send(encode_update(codec, channel, |serializer: Serializer| {
				value.describe(serializer);
			}));
		});
		self.sources.write().push((channel, starter));
		channel
	}

	// A client subscribed: start the channel's forward. `sub` fires immediately
	// with the current value, so a subscriber gets the present state before any
	// change.
	fun start(self, channel: i32) {
		for entry in self.sources.read() {
			let (id, starter) = entry;
			if id == channel {
				self.live.write().push((channel, starter()));
			}
		}
	}

	// A client unsubscribed: dispose the forward for that channel.
	fun stop(self, channel: i32) {
		mut kept: List<(i32, Subscription)> = [];
		for entry in self.live.read() {
			let (id, subscription) = entry;
			if id == channel {
				subscription.dispose();
			} else {
				kept.push((id, subscription));
			}
		}
		self.live.write() = kept;
	}

	// One inbound control frame: `Subscribe`/`Unsubscribe` route to
	// `start`/`stop`. A malformed frame — or a stray `Update`, which only ever
	// flows server → client — is dropped.
	fun receive(self, frame: Frame) {
		let deserializer = (self.codec.reader)(frame);
		let tag = (deserializer.variant_tag)();
		(deserializer.begin_variant)(tag, 1);
		let channel = (deserializer.i32_value)();
		match (deserializer.failed)() {
			Some(let _reason) => {},
			None => {
				match tag {
					"Subscribe" => self.start(channel),
					"Unsubscribe" => self.stop(channel),
					_ => {},
				}
			},
		}
	}
}

impl ReactiveServer with Disposable {
	// Tear the session down: stop every live forward. Starters keep no
	// subscription of their own, so clearing the tables releases everything
	// this session held on the app's signals — after this, changes no longer
	// reach (or reference) this wire.
	fun dispose(self) {
		for entry in self.live.read() {
			let (channel, subscription) = entry;
			subscription.dispose();
		}
		self.live.write() = [];
		self.sources.write() = [];
	}
}

// --- Client side: the remote handle -----------------------------------------

// The reactive protocol's client half: routes each inbound `Update` frame to
// the typed mirror of its subscribed channel. `source<T>` hands out a
// `RemoteSource<T>` — the type binds at the call site (an annotated `let`, or
// the generated client's mirror wiring).
struct ReactiveClient {
	transport: DuplexEnd,
	codec: Codec,
	// Per subscribed channel: the deliverer that decodes an `Update`'s payload
	// at the channel's type (fixed by `source<T>`) and lands it in the mirror.
	// The id is a CELL shared with the channel's `RemoteSource` — a reconnect
	// rebind moves both in one write (proposal/transport-robustness.md §2.5).
	routes: Shared<List<(Shared<i32>, |Frame| void)>>,
}

impl ReactiveClient {
	fun new(transport: DuplexEnd, codec: Codec): ReactiveClient {
		let client = ReactiveClient {
			transport,
			codec,
			routes = Shared::new([]),
		};
		(client.transport).on_frame(|frame| {
			// every inbound frame is handled in a turn (proposal/reactive-batching.md)
			batch(|| client.receive(frame));
		});
		client
	}

	// A remote handle for a channel: a typed local mirror (`Signal<Option<T>>`,
	// `None` until the first update lands) kept in sync by inbound `Update`
	// frames, wrapped as a `RemoteSource<T>` whose `sub` also opens the channel.
	fun source<T: Wire>(self, channel: i32): RemoteSource<T> {
		let cache: Signal<Option<T>> = Signal::new(None);
		let codec = self.codec;
		// Deliver one routed `Update`: re-open the frame (the envelope was only
		// routed, not consumed) and rebuild the payload at this channel's type.
		// A malformed update is dropped — the mirror keeps its last good value.
		let deliver = |frame: Frame| {
			let deserializer = (codec.reader)(frame);
			let tag = (deserializer.variant_tag)();
			(deserializer.begin_variant)(tag, 2);
			let _channel = (deserializer.i32_value)();
			let value: T = T::rebuild(deserializer);
			match (deserializer.failed)() {
				Some(let _reason) => {},
				None => cache.set(Some(value)),
			}
		};
		let channel_cell = Shared::new(channel);
		self.routes.write().push((channel_cell, deliver));
		RemoteSource {
			channel = channel_cell,
			subscribe = Shared::new(encode_control(self.codec, "Subscribe", channel)),
			wanted = Shared::new(false),
			transport = self.transport,
			cache,
		}
	}

	// One inbound frame: an `Update` fans out to its channel's deliverers
	// (each re-opens the frame at its own type); anything else is ignored.
	fun receive(self, frame: Frame) {
		let deserializer = (self.codec.reader)(frame);
		let tag = (deserializer.variant_tag)();
		(deserializer.begin_variant)(tag, 2);
		let channel = (deserializer.i32_value)();
		if tag == "Update" {
			match (deserializer.failed)() {
				Some(let _reason) => {},
				None => {
					for route in self.routes.read() {
						let (id, deliver) = route;
						if id.read() == channel {
							deliver(frame);
						}
					}
				},
			}
		}
	}
}

// A remote read-only handle, typed end to end: the local mirror holds
// `Option<T>` — `None` until the first update arrives, the typed replacement
// for the old `""` sentinel — `sub` opens the channel (a pre-encoded
// `Subscribe`) and delivers each decoded value, and `get` samples the mirror.
// The write half stays on the server: this is the reactive split — client
// code can't write a server signal. Over an in-process transport the server's
// immediate current-value `Update` lands synchronously, so the observer fires
// at once with the present state; over a real wire it fires when that update
// arrives.
struct RemoteSource<T> {
	// Cells, not plain fields: a reconnect rebind points the mirror at the
	// fresh connection's channel (the id cell is SHARED with the
	// `ReactiveClient` route, so routing moves in the same write).
	channel: Shared<i32>,
	// The channel's `Subscribe` frame — re-encoded on rebind.
	subscribe: Shared<Frame>,
	// Whether anyone ever subscribed — a rebind re-subscribes only mirrors
	// that are actually watched.
	wanted: Shared<bool>,
	transport: DuplexEnd,
	cache: Signal<Option<T>>,
}

impl RemoteSource<type T> {
	// The mirror's current value: `None` until the first update lands.
	fun get(self): Option<T> {
		self.cache.get()
	}

	[must_use]
	fun sub(self, observer: |T| void): Subscription {
		self.wanted.write() = true;
		(self.transport).send(self.subscribe.read());
		self.cache.sub(|value| {
			match value {
				Some(let present) => observer(present),
				None => {},
			}
		})
	}

	// Point the mirror at a fresh channel after a reconnect
	// (proposal/transport-robustness.md §2.5) and, when watched, re-subscribe
	// — the server's immediate current-value `Update` resyncs the cache.
	fun rebind(self, channel: i32, subscribe: Frame) {
		self.channel.write() = channel;
		self.subscribe.write() = subscribe;
		if self.wanted.read() {
			(self.transport).send(subscribe);
		}
	}
}

// `connect_socket` with the transport failure mapped into `RpcError` — the
// generated `connect` opens with `dial_for_service(url)!`. Hand-written here
// (rather than inline in the expansion) so the conversion types in std's own
// unit; see backlog B21 for the load-order sensitivity that pushed it out of
// the template.
fun dial_for_service(url: str): Result<SocketDuplex, RpcError> {
	let dialed = connect_socket(url);
	dialed.map_err(|reason: str| RpcError::Transport(reason))
}

// Re-attach a generated client's mirrors after a reconnect (§2.5): re-verify
// the contract (a REDEPLOYED server with a drifted surface must not feed
// typed mirrors — the duplex closes for good instead), re-`__attach` under
// the fresh connection id, and rebind each mirror positionally (the
// `__attach` reply is ordered by the service's exposed-field order). The
// generated `connect` pushes one `on_reconnect` hook calling this.
fun reattach_mirrors(
	socket: SocketDuplex,
	transport: SocketTransport,
	codec: Codec,
	expected_contract: str,
	rebinds: List<|i32, Frame| void>,
) {
	let remote: Result<str, RpcError> = call(transport, codec, "__contract", []);
	match remote {
		// Unreachable again already — the next drop cycle handles it.
		Err(let _unreachable) => {},
		Ok(let hash) => {
			if hash == expected_contract {
				let connection = socket.connection.read();
				let attached: Result<List<i32>, RpcError> = call(transport, codec, "__attach", [|serializer: Serializer| connection.describe(serializer)]);
				match attached {
					Err(let _failed) => {},
					Ok(let channels) => {
						mut index = 0;
						for rebind in rebinds {
							let channel = channels[index];
							rebind(channel, encode_control(codec, "Subscribe", channel));
							index += 1;
						}
					},
				}
			} else {
				// The service surface changed under us: a typed desync in
				// waiting. Close for good; the app restarts on its own terms.
				socket.state.set(ConnectionState::Closed);
				socket.socket.read().close();
			}
		},
	}
}

// The `[service]` generator (transport-rpc.md §4.2) as a prelude macro.
// This module is NOT always loaded — a `[service]` item in any file seeds
// it (the loader's `contains_service` scan), so the macro is registered
// before expansion wherever it's needed.

// djb2 over the canonical contract surface (Q6 v2), rendered as 8 hex digits
// — the same fingerprint on both generated sides.
macro fun service_hash(surface: str): str {
	mut hash = 5381u32;
	mut index = 0;
	let length = surface.len();
	for index < length {
		hash = (hash * 33u32) ^ surface.code_at(index);
		index = index + 1;
	}
	mut hex = "";
	mut nibble = 0;
	for nibble < 8 {
		let shift = 28u32 - (4u32 * u32_of_nibble(nibble));
		hex = hex + nibble_char((hash >> shift) & 15u32);
		nibble = nibble + 1;
	}
	hex
}

// (i32 loop counter → u32 shift operand; a dedicated conversion keeps the
// hash all-u32. Number() is the identity on an in-range integer.)
macro fun u32_of_nibble(value: i32): u32 {
	if value == 0 { ret 0u32; }
	if value == 1 { ret 1u32; }
	if value == 2 { ret 2u32; }
	if value == 3 { ret 3u32; }
	if value == 4 { ret 4u32; }
	if value == 5 { ret 5u32; }
	if value == 6 { ret 6u32; }
	7u32
}

macro fun nibble_char(digit: u32): str {
	if digit == 0u32 { ret "0"; }
	if digit == 1u32 { ret "1"; }
	if digit == 2u32 { ret "2"; }
	if digit == 3u32 { ret "3"; }
	if digit == 4u32 { ret "4"; }
	if digit == 5u32 { ret "5"; }
	if digit == 6u32 { ret "6"; }
	if digit == 7u32 { ret "7"; }
	if digit == 8u32 { ret "8"; }
	if digit == 9u32 { ret "9"; }
	if digit == 10u32 { ret "a"; }
	if digit == 11u32 { ret "b"; }
	if digit == 12u32 { ret "c"; }
	if digit == 13u32 { ret "d"; }
	if digit == 14u32 { ret "e"; }
	"f"
}

// `.on("name", |request| { ..statements.. })` — a dispatcher route whose
// handler decodes arguments from `request` in a block closure.
macro fun route_block(name: str, statements: List<str>): str {
	import macro_std::build::{ quote, indent };

	// The route body runs inside a fresh per-dispatch TURN
	// (proposal/reactive-turns.md): the generated closure below is STORED at
	// registration (capture-at-creation would see nothing), but the `turn`
	// call happens at INVOCATION, and its literal contains the DIRECT call
	// into the user's handler method — so the turn threads compile-time into
	// real handler code, and one request's signal writes settle as one wave.
	let label = quote(name);
	mut closure = i".on({label}, |request| \{\n";
	closure = closure + indent("turn(FlushPolicy::AtEnd, || {", 1) + "\n";
	for statement in statements {
		closure = closure + indent(statement, 2) + "\n";
	}
	closure = closure + indent("})", 1) + "\n";
	closure + "})"
}

macro fun service(item: Item): Source {
	import macro_std::option::Option::{ self, Some, None };
	import macro_std::build::{ impl_of, fun_of, match_of, struct_of, quote, join, indent };

	let target = match item.as_service() {
		Some(let found) => found,
		None => ServiceItem { name = "?", client_name = "?", fields = [], methods = [] },
	};
	// The [expose]d fields: each `Signal<Element>` surfaces its element (a
	// malformed field renders `_`, erroring clearly at the generated site).
	mut exposed_names: List<str> = [];
	mut exposed_elements: List<str> = [];
	for field in target.fields {
		if field.exposed {
			exposed_names.push(field.name);
			if field.type_.name == "Signal" && field.type_.arguments.len() == 1 {
				match field.type_.arguments.get(0) {
					Some(let element) => exposed_elements.push(element.render()),
					None => exposed_elements.push("_"),
				}
			} else {
				exposed_elements.push("_");
			}
		}
	}
	// The contract surface + its hash — shared verbatim by both sides.
	mut surface = "";
	for method in target.methods {
		surface = surface + method.name + "(";
		mut first = true;
		for parameter in method.parameters {
			if parameter.name == "self" {
				jump continue;
			}
			if first {
				first = false;
			} else {
				surface = surface + ",";
			}
			surface = surface + parameter.type_.render();
		}
		surface = surface + ")->" + method.return_type.render() + ";";
	}
	mut expose_index = 0;
	for field_name in exposed_names {
		let element = match exposed_elements.get(expose_index) {
			Some(let found) => found,
			None => "_",
		};
		surface = surface + "expose:" + field_name + ":" + element + ";";
		expose_index = expose_index + 1;
	}
	let hash = service_hash(surface);

	// --- The dispatcher: one route per [rpc] method, handlers capturing `self`.
	mut routes: List<str> = [];
	for method in target.methods {
		mut statements: List<str> = [];
		mut arguments: List<str> = [];
		mut arity = 0;
		for parameter in method.parameters {
			if parameter.name == "self" {
				jump continue;
			}
			statements.push(i"let {parameter.name}: {parameter.type_.render()} = arg(request, {arity});");
			arguments.push(parameter.name);
			arity = arity + 1;
		}
		let label = quote(method.name);
		if arity == 0 {
			routes.push(i".on({label}, |_| reply(self.{method.name}()))");
		} else {
			let argument_list = join(arguments, ", ");
			statements.push(match_of("decode_failed(request)")
				.arm("Option::Some(let reason)", "RpcOutcome::Failure(RpcError::Decode(reason))")
				.arm("Option::None", i"reply(self.{method.name}({argument_list}))")
				.render());
			routes.push(route_block(method.name, statements));
		}
	}
	routes.push(".on(" + quote("__contract") + ", |_| reply(self.contract_hash()))");
	mut exposures: List<str> = [];
	for field_name in exposed_names {
		exposures.push(i"session.expose(self.{field_name})");
	}
	let exposure_list = join(exposures, ", ");
	let attach_reply = match_of("session_of(connection)")
		.arm_block("Option::Some(let session)", [i"let channels: List<i32> = [{exposure_list}];", "reply(channels)"])
		.arm("Option::None", "RpcOutcome::Failure(RpcError::Remote(" + quote("unknown connection") + "))")
		.render();
	mut attach_statements: List<str> = [];
	attach_statements.push("let connection: i32 = arg(request, 0);");
	attach_statements.push(match_of("decode_failed(request)")
		.arm("Option::Some(let reason)", "RpcOutcome::Failure(RpcError::Decode(reason))")
		.arm("Option::None", attach_reply)
		.render());
	routes.push(route_block("__attach", attach_statements));
	mut chain = "Dispatcher::new()";
	for route in routes {
		chain = chain + "\n" + indent(route, 1);
	}
	let dispatcher = fun_of("dispatcher")
		.parameter("self")
		.returns("Dispatcher")
		.expr(chain);
	let contract_hash = fun_of("contract_hash")
		.parameter("self")
		.returns("str")
		.expr(quote(hash));
	let service_impl = impl_of(target.name).method(dispatcher).method(contract_hash).render();

	// --- The client sibling: a transport + a mirror per exposed field.
	mut client_struct = struct_of(target.client_name)
		.generics("<T: Transport>")
		.field("transport: T")
		.field("codec: Codec");
	mut mirror_index = 0;
	for field_name in exposed_names {
		let element = match exposed_elements.get(mirror_index) {
			Some(let found) => found,
			None => "_",
		};
		client_struct = client_struct.field(i"{field_name}: RemoteSource<{element}>");
		mirror_index = mirror_index + 1;
	}
	mut client_impl = impl_of(target.client_name).generics("<type T>");
	for method in target.methods {
		mut stub = fun_of(method.name).parameter("self");
		mut describers: List<str> = [];
		for parameter in method.parameters {
			if parameter.name == "self" {
				jump continue;
			}
			stub = stub.parameter(i"{parameter.name}: {parameter.type_.render()}");
			describers.push(i"|serializer: Serializer| {parameter.name}.describe(serializer)");
		}
		let label = quote(method.name);
		let describer_list = join(describers, ", ");
		stub = stub
			.returns(i"Result<{method.return_type.render()}, RpcError>")
			.expr(i"call(self.transport, self.codec, {label}, [{describer_list}])");
		client_impl = client_impl.method(stub);
	}
	let verify = fun_of("verify")
		.parameter("self")
		.returns("Result<bool, RpcError>")
		.line("let remote: Result<str, RpcError> = call(self.transport, self.codec, " + quote("__contract") + ", []);")
		.expr("Result::Ok(remote! == self.contract_hash())");
	client_impl = client_impl.method(verify).method(contract_hash);

	// --- Client::connect (§4.2): contract enforcement, __attach, mirrors —
	// --- and the reconnect hook that re-attaches them (K6).
	let complaint = quote("the server reports a different service surface");
	mut connect = fun_of("connect")
		.parameter("url: str")
		.parameter("codec: Codec")
		.returns(i"Result<{target.client_name}<SocketTransport>, RpcError>")
		.line("let socket = dial_for_service(url)!;")
		.line("let transport = socket.transport();")
		.line("let remote: Result<str, RpcError> = call(transport, codec, " + quote("__contract") + ", []);")
		.line("if remote! != " + quote(hash) + " {\n" + indent(i"ret Result::Err(RpcError::Contract({complaint}));", 1) + "\n}")
		.line("let connection = socket.connection.read();")
		.line("let attached: Result<List<i32>, RpcError> = call(transport, codec, " + quote("__attach") + ", [|serializer: Serializer| connection.describe(serializer)]);")
		.line("let channels = attached!;")
		.line("let reactive = ReactiveClient::new(bridge(socket), codec);");
	mut ok_fields: List<str> = [];
	ok_fields.push("transport = transport");
	ok_fields.push("codec = codec");
	mut rebind_lines: List<str> = [];
	mut channel_index = 0;
	for field_name in exposed_names {
		let element = match exposed_elements.get(channel_index) {
			Some(let found) => found,
			None => "_",
		};
		connect = connect.line(i"let mirror_{field_name}: RemoteSource<{element}> = reactive.source(channels[{channel_index}]);");
		ok_fields.push(i"{field_name} = mirror_{field_name}");
		rebind_lines.push(i"|channel: i32, subscribe: Frame| mirror_{field_name}.rebind(channel, subscribe)");
		channel_index = channel_index + 1;
	}
	// The reconnect hook: re-verify the contract, re-attach under the fresh
	// connection id, rebind every mirror positionally (transport-robustness §2.5).
	let rebind_list = if rebind_lines.len() > 0 {
		"[\n" + indent(join(rebind_lines, ",\n"), 1) + ",\n]"
	} else {
		"[]"
	};
	connect = connect
		.line(i"let rebinds: List<|i32, Frame| void> = {rebind_list};")
		.line("socket.on_reconnect.write().push(|| {\n" + indent("reattach_mirrors(socket, transport, codec, " + quote(hash) + ", rebinds);", 1) + "\n});");
	let field_lines = join(ok_fields, ",\n");
	connect = connect.expr(i"Result::Ok({target.client_name} \{\n" + indent(field_lines, 1) + "\n})");
	let connect_impl = impl_of(target.client_name).generics("<SocketTransport>").method(connect).render();

	let imports = "import std::rpc::{ Transport, Dispatcher, RpcError, RpcOutcome, RemoteSource, call, arg, reply, decode_failed, session_of, dial_for_service, SocketDuplex, SocketTransport, bridge, ReactiveClient, reattach_mirrors };\n"
		+ "import std::wire::{ Codec, Serializer, Frame };\n"
		+ "import std::result::Result;\n"
		+ "import std::option::Option;\n"
		+ "import std::reactive::{ turn, FlushPolicy };\n";
	source(imports + service_impl + client_struct.render() + client_impl.render() + connect_impl)
}
