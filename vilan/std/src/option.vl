import pkg::compare::PartialEq;
import pkg::default::Default;
import pkg::operators::{ Lift, Try, Verdict };
import pkg::io::panic;
import pkg::result::Result::{ self, Ok, Err };

enum Option<T> {
	Some(T),
	None,
}

use Option::{ Some, None };

// `!` on an `Option`: `Some` is good; `None` is bad, its residual `void` (the
// unit — the absence carries no information), rebuilt as `None` at the
// enclosing function's element type (proposal/try-and-lift.md).
impl Option<type T> with Try<T, void> {
	fun verdict(self): Verdict<T, void> {
		match self {
			Some(let value) => Verdict::Good(value),
			None => Verdict::Bad(void),
		}
	}

	fun from_bad(bad: void): Option<T> {
		None
	}
}

// `?.` on an `Option` maps `Some` (or flattens an `Option`-yielding chain);
// `None` short-circuits.
impl Option<type T> with Lift {}

impl Option<type T> {
	/// Take the value out, leaving `None` behind: `Some(v)` becomes `None` and
	/// yields `Some(v)`; `None` yields `None` (and stays `None`). This is the one
	/// sanctioned partial move for a resource field — `self.slot.take()` moves a
	/// resource out of a live aggregate (destruction.md §5/§6) — and the core of
	/// the conditional-teardown idiom `match opt.take() { Some(let c) => drop(c),
	/// None => {} }`. Useful for data too.
	external fun take(&mut self): Option<T>;

	/// Put `value` in and return the old contents: the slot becomes `Some(value)`
	/// and yields whatever was there before (`Some(old)` or `None`). The caller
	/// then owns the old value.
	external fun replace(&mut self, value: T): Option<T>;

	fun is_some(self): bool {
		self is Some(_)
	}

	fun is_some_and(self, fn: |T| bool): bool {
		match self {
			Some(let x) => fn(x),
			_ => false,
		}
	}

	fun is_none(self): bool {
		self is None
	}

	fun is_none_or(self, fn: |T| bool): bool {
		match self {
			Some(let x) => fn(x),
			_ => true,
		}
	}

	fun unwrap(self): T {
		match self {
			Some(let x) => x,
			_ => panic("expected Some but got None"),
		}
	}

	fun unwrap_or(self, fallback: T): T {
		match self {
			Some(let x) => x,
			_ => fallback,
		}
	}

	fun unwrap_or_else(self, fn: || T): T {
		match self {
			Some(let x) => x,
			_ => fn(),
		}
	}

	fun map<U>(self, fn: |T| U): Option<U> {
		match self {
			Some(let x) => Some(fn(x)),
			None => None,
		}
	}

	fun map_or<U>(self, fn: |T| U, fallback: U): U {
		match self {
			Some(let x) => fn(x),
			_ => fallback,
		}
	}

	fun map_or_else<U>(self, fn: |T| U, fallback: || U): U {
		match self {
			Some(let x) => fn(x),
			_ => fallback(),
		}
	}

	fun map_or_default<U: Default>(self, fn: |T| U): U {
		match self {
			Some(let x) => fn(x),
			_ => U::default(),
		}
	}

	fun inspect(self, fn: |T| void): Self {
		match self {
			Some(let x) => fn(x),
			_ => {}
		}
		self
	}

	fun ok_or<E>(self, err: E): Result<T, E> {
		match self {
			Some(let x) => Ok(x),
			_ => Err(err),
		}
	}

	fun ok_or_else<E>(self, err: || E): Result<T, E> {
		match self {
			Some(let x) => Ok(x),
			_ => Err(err()),
		}
	}

	fun and<U>(self, b: Option<U>): Option<U> {
		match self {
			Some(_) => b,
			_ => None,
		}
	}

	fun and_then<U>(self, fn: |T| Option<U>): Option<U> {
		match self {
			Some(let x) => fn(x),
			_ => None,
		}
	}

	fun filter(self, predicate: |T| bool): Option<T> {
		self.and_then(|x| predicate(x).then_some(x))
	}

	fun or(self, b: Option<T>): Option<T> {
		match self {
			Some(_) => self,
			_ => b,
		}
	}

	fun or_else(self, fn: || Option<T>): Option<T> {
		match self {
			Some(_) => self,
			_ => fn(),
		}
	}

	fun xor(self, b: Option<T>): Option<T> {
		match (self, b) {
			(Some(_), None) => self,
			(None, Some(_)) => b,
			_ => None,
		}
	}

	fun zip<U>(self, peer: Option<U>): Option<(T, U)> {
		match (self, peer) {
			(Some(let x), Some(let y)) => Some((x, y)),
			_ => None,
		}
	}
}

impl Option<type T: Default> {
	fun unwrap_or_default(self): T {
		match self {
			Some(let x) => x,
			_ => T::default(),
		}
	}
}

impl Option<(type T, type U)> {
	fun unzip(self): (Option<T>, Option<U>) {
		match self {
			Some((let x, let y)) => (Some(x), Some(y)),
			_ => (None, None),
		}
	}
}

impl Option<Result<type T, type E>> {
	fun transpose(self): Result<Option<T>, E> {
		match self {
			Some(Ok(let x)) => Ok(Some(x)),
			Some(Err(let x)) => Err(x),
			_ => Ok(None),
		}
	}
}

impl Option<Option<type T>> {
	fun flatten(self): Option<T> {
		match self {
			Some(let x) => x,
			_ => None,
		}
	}
}

impl Option<type T> with Default {
	fun default(): Option<T> {
		None
	}
}

impl Option<type T: PartialEq> with PartialEq {
	fun eq(self, b: Option<T>): bool {
		match (self, b) {
			(Some(let x), Some(let y)) => x == y,
			(None, None) => true,
			_ => false,
		}
	}
}

// `then_some` lives here rather than in `boolean.vl` so that the always-loaded
// core `bool` module stays dependency-free (it would otherwise have to import
// `Option`). An `impl` block does not need to share a module with the type it
// extends.
impl bool {
	fun then_some<T>(self, value: T): Option<T> {
		if self {
			Some(value)
		} else {
			None
		}
	}
}

// `parse_i32` lives here (not in the always-loaded `string.vl`) because its
// result is an `Option`, which the core `str` module must not depend on. An
// `impl` block does not need to share a module with the type it extends.
impl str {
	/// STRICT: the whole (whitespace-trimmed) text must be a decimal integer in
	/// i32 range — `"1.5"`, `"12x"`, `""`, and out-of-range values are `None`,
	/// never a truncation.
	external fun parse_i32(self): Option<i32>;

	/// STRICT on shape (`"3.14x"` is `None`, unlike a liberal parseFloat), but
	/// any full numeric text the host accepts — including `"1e3"` and
	/// `"Infinity"` — parses.
	external fun parse_f64(self): Option<f64>;
}

// `List`'s `Option`-returning methods live here (not `list.vl`) so the
// always-loaded core stays off the `option`/`result` chain — same reason as
// `then_some`/`parse_i32` above. `get` returns a copy of the element.
impl List<type T> {
	external fun get(self, index: i32): Option<T>;

	external fun pop(&mut self): Option<T>;

	fun first(self): Option<T> {
		self.get(0)
	}

	/// `get(len - 1)`: for an empty list `len - 1` is `-1`, which `get` reports as
	/// `None`.
	fun last(self): Option<T> {
		self.get(self.len() - 1)
	}
}
