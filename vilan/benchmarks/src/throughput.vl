// RPC round-trip throughput: sequential calls (each awaited — honest latency,
// no pipelining) over the in-process transport and over real HTTP on
// localhost, with the JSON and binary codecs side by side. Timings vary by
// machine; the report prints rates, not asserts.

import std::print;
import std::shared::Shared;
import std::json::{ Json, json_codec };
import std::binary::binary_codec;
import std::wire::{ Serializer, Codec };
import std::option::Option::{ Some, None };
import std::result::Result::{ self, Ok, Err };
import std::time::now;
import std::rpc::{
	local_rpc, Dispatcher, RpcError, RpcOutcome, RpcProtocol, HttpTransport, Transport,
	connect_socket, call, arg, reply, decode_failed,
};
import std::rpc_server::{ serve_rpc, serve_connected };
import std::http::Response;
import pkg::report::{ section, rate, round };

fun add_protocol(codec: Codec): RpcProtocol {
	let total: Shared<i32> = Shared::new(0);
	Dispatcher::new()
		.on("add", |request| {
			let by: i32 = arg(request, 0);
			match decode_failed(request) {
				Some(let reason) => RpcOutcome::Failure(RpcError::Decode(reason)),
				None => {
					total.write() = total.read() + by;
					reply(total.read())
				},
			}
		})
		.into_protocol(codec)
}

// `calls` sequential round-trips over `transport`; returns elapsed ms.
fun drive<T: Transport>(transport: T, codec: Codec, calls: i32): f64 {
	let started = now();
	mut index = 0;
	for index < calls {
		let one = 1;
		let outcome: Result<i32, RpcError> = call(transport, codec, "add", [|s: Serializer| one.describe(s)]);
		match outcome {
			Ok(let value) => {},
			Err(let error) => print(i"call failed: {error.to_json()}"),
		}
		index += 1;
	}
	now() - started
}

fun run(finished: || void) {
	section("rpc round-trip throughput (sequential)");

	let local_calls = 2000;
	let local_json = drive(local_rpc(add_protocol(json_codec())), json_codec(), local_calls);
	print(i"in-process json: {local_calls} calls in {round(local_json)} ms -> {rate(local_calls, local_json)} calls/sec");
	let local_binary = drive(local_rpc(add_protocol(binary_codec())), binary_codec(), local_calls);
	print(i"in-process binary: {local_calls} calls in {round(local_binary)} ms -> {rate(local_calls, local_binary)} calls/sec");

	let http_calls = 200;
	serve_rpc(48231, add_protocol(json_codec()), |server| {
		let elapsed = drive(HttpTransport { url = "http://localhost:48231/" }, json_codec(), http_calls);
		let average_us = round(elapsed * 1000.0 / http_calls);
		print(i"http json: {http_calls} calls in {round(elapsed)} ms -> {rate(http_calls, elapsed)} calls/sec ({average_us} us avg)");
		// The binary codec end-to-end over real HTTP rides serve_connected's
		// byte-reading /rpc route; the same server's upgrade path then serves
		// the WebSocket-multiplexed measurement (json — the socket transport
		// multiplexes text frames).
		serve_connected(
			48233,
			add_protocol(binary_codec()),
			|id, end| {},
			|id| {},
			|request| Response::builder().code(404).body("benchmark").build(),
			|| {
				let binary_elapsed = drive(HttpTransport { url = "http://localhost:48233/rpc" }, binary_codec(), http_calls);
				let binary_average_us = round(binary_elapsed * 1000.0 / http_calls);
				print(i"http binary: {http_calls} calls in {round(binary_elapsed)} ms -> {rate(http_calls, binary_elapsed)} calls/sec ({binary_average_us} us avg)");
				serve_connected(
					48234,
					add_protocol(json_codec()),
					|id, end| {},
					|id| {},
					|request| Response::builder().code(404).body("benchmark").build(),
					|| {
						let socket = connect_socket("ws://localhost:48234");
						let ws_elapsed = drive(socket.transport(), json_codec(), http_calls);
						let ws_average_us = round(ws_elapsed * 1000.0 / http_calls);
						print(i"ws multiplex json: {http_calls} calls in {round(ws_elapsed)} ms -> {rate(http_calls, ws_elapsed)} calls/sec ({ws_average_us} us avg)");
						finished();
					},
				);
			},
		);
	});
}
