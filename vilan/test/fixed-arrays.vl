// fixed-arrays.vl — `[T; n]` fixed-length arrays (proposal/fixed-arrays.md): the
// repeat literal `[value; n]`, context-directed `[a, b, c]` under a `[T; n]`
// annotation, index read/write, `&mut arr[i]` element views, `for` iteration,
// value-copy independence (scalar and aggregate), params/returns, nesting, and
// `.len()` (folds to the constant; a call subject still evaluates — §10), and
// destructuring `let [a, b] = arr` (irrefutable, count = the type's length).
import std::print;

struct Cell {
	n: i32,
}

fun total(values: [i32; 3]): i32 {
	mut sum = 0;
	for value in values {
		sum = sum + value;
	}
	sum
}

fun make(): [i32; 2] {
	[5; 2] // repeat literal, returned
}

fun bump(view: &mut i32) {
	view += 100; // write-through an element view
}

fun main() {
	let zeros = [0; 4]; // [i32; 4]
	print(zeros[0]); // 0

	mut buf: [i32; 3] = [1, 2, 3]; // context-directed list literal
	buf[1] = 20; // index write
	print(buf[1]); // 20
	print(total(buf)); // 24 (passed as a parameter)

	let view = &mut buf[2];
	bump(view);
	print(buf[2]); // 103

	let copy = buf; // value copy
	buf[0] = 99;
	print(copy[0]); // 1 — independent of buf

	mut cells = [Cell { n = 7 }; 3]; // aggregate repeat — independent slots
	cells[0].n = 42;
	print(cells[0].n); // 42
	print(cells[1].n); // 7

	let two = make();
	print(two[0] + two[1]); // 10 (returned array)

	let grid: [[i32; 2]; 2] = [[1, 2], [3, 4]]; // nested
	print(grid[1][0]); // 3

	print(buf.len()); // 3 — folds to the constant
	print(grid[0].len()); // 2 — a subscript subject stays evaluated (bounds check)
	print(make().len()); // 2 — a call subject runs, `.length` read in place

	let [left, right] = grid; // destructuring — nested [i32; 2] copies
	let [l0, l1] = left;
	print(l0 + l1); // 3
	mut [r0, r1] = right;
	r0 = r0 + 100;
	print(r0); // 103
	print(grid[1][0]); // 3 — the source is untouched
	print(r1); // 4
}
