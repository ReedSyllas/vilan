// A hand-written RPC + reactive runtime (roadmap P6 / proposal/transport-rpc.md). The
// library is a *guide*, not a generator: it gives you a codec, transports, and two
// sibling **protocols** over them — request/response (`RpcProtocol`) and pub/sub
// (`ReactiveProtocol`, §8) — and a paradigm for using them. This file works that paradigm
// by hand; the reusable runtime is in `rpc.vl`. In-process, so it runs with no network.
//
// The `[service]`/`[rpc]` codegen sugar isn't built yet, so the hand-written `call`/
// `Dispatcher` foundation (rpc.vl §4.1) stands in for the generated stub/dispatcher;
// `[derive(Wire)]` — the data boundary (§3) — is real. The *paradigm* is the subject: a
// rich domain type with an explicit projection to a wire DTO, a sensitive type that
// cannot cross the wire, and a server `Signal` observed remotely as a `Source` — with
// writes coalesced per wire turn (reactive batching: `batch` around inbound handling).
//
//     vilan run vilan/examples/rpc

import std::print;
import std::json::{ Json, FromJson };
import std::option::Option::{ self, Some, None };
import std::result::Result::{ self, Ok, Err };
import std::shared::Shared;
import std::reactive::{ batch, Signal, Source };
import std::wire::{ Serializer, Codec };
import std::json::json_codec;
import std::rpc::{
	Transport, LocalTransport, RpcError, RpcOutcome,
	local_rpc, Dispatcher, call, arg, reply, decode_failed,
	duplex_pair, ReactiveServer, ReactiveClient, RemoteSource,
};

// --- The data boundary (would live in a `common` library, on both sides) ------

// `Password` deliberately has NO codec — no `[derive(Json)]`, no hand-written
// `to_json`. That is the capability boundary (proposal §3): a value of this type
// *cannot* be encoded, so nothing that holds one can cross the wire. Sensitive data
// lives behind such a type, declared once, impossible to forget at a call site.
struct Password {
	hash: str,
}

impl Password {
	// A stand-in "hash" (a real one would be bcrypt). The point is only that the
	// stored form is derived from the plaintext and never leaves the server.
	fun new(plaintext: str): Password {
		Password { hash = "sha256:" + plaintext }
	}

	// Server-side verification: the stored hash never leaves this type, let alone the
	// server — comparison is the only operation exposed.
	fun matches(self, plaintext: str): bool {
		self.hash == "sha256:" + plaintext
	}
}

// The rich, server-side domain type. It holds a `Password`, so it CANNOT be Wire —
// `[derive(Wire)] struct User { .. }` does not compile: `Password` is not Wire, so the
// compiler rejects the field (the boundary, enforced by construction — §3). `User`
// therefore never crosses the wire; only its explicit projection does.
struct User {
	id: i32,
	username: str,
	password: Password,
}

impl User {
	// The explicit projection to the wire shape. Developer-written, so it chooses what
	// crosses: it drops `password` (which has nowhere to go — `Password` isn't
	// encodable) and adds a computed `handle` that the domain type has no field for.
	// The wire shape diverges freely from the source.
	fun to_wire(self): WireUser {
		WireUser {
			id = self.id,
			username = self.username,
			handle = "@" + self.username,
		}
	}
}

// The wire DTO — every field is Wire, so the whole struct is. This is all the client
// ever sees; it has never heard of `Password`. `[derive(Wire)]` enforces exactly that: a
// non-Wire field (like `Password`) would be a compile error (§3).
[derive(Wire)]
struct WireUser {
	id: i32,
	username: str,
	handle: str,
}

// --- Server side: the implementation + the dispatcher ------------------------

// The server's real logic: a tiny fixed "database", returning the rich domain `User`
// (password and all). `None` is an application-level "not found" (part of the return
// type), not an RpcError.
fun lookup_user(id: i32): Option<User> {
	match id {
		1 => Some(User { id = 1, username = "ada", password = Password::new("hunter2") }),
		2 => Some(User { id = 2, username = "bob", password = Password::new("swordfish") }),
		_ => None
	}
}

// Find a user by name — `login`'s lookup (a real database would index by username).
fun find_user(username: str): Option<User> {
	match username {
		"ada" => lookup_user(1),
		"bob" => lookup_user(2),
		_ => None,
	}
}

// The dispatcher: register each method's handler over the `Dispatcher` router (rpc.vl §4.1).
// A handler decodes its arguments at their parameter type (`arg`), calls the impl, **projects
// the domain result to its wire shape**, and encodes the reply (`reply`). Envelope decode/encode
// and routing are the library's job — a handler is the pure application logic, exactly what a
// `[service]` derive would generate from a `[rpc]` method (proposal §4). The projection is the
// one place the boundary is crossed.
fun accounts_dispatcher(): Dispatcher {
	Dispatcher::new().on("get_user", |request| {
		let id: i32 = arg(request, 0);
		// A garbled request never reaches the impl: the decode gate turns it
		// into a clean `RpcError::Decode` (§4.1 single-pass).
		match decode_failed(request) {
			Some(let reason) => RpcOutcome::Failure(RpcError::Decode(reason)),
			None => {
				// `reply(lookup_user(id))` would NOT compile — `User` has no codec.
				// The projection to the wire shape is mandatory: the safety guarantee.
				let wire_user = match lookup_user(id) {
					Some(let user) => Some(user.to_wire()),
					None => None,
				};
				reply(wire_user)
			},
		}
	})
}

// --- Client side: the typed stub ---------------------------------------------

// The client is an object stub holding the transport. The trait bound is declared once,
// on the struct (so the field's type carries it); the impl infers it (`impl
// AccountsClient<type T>`, no restated `: Transport`). Each method is now one line over the
// `call` helper (rpc.vl §4.1): it passes the `T`-typed transport to a generic
// `call<_, Tx: Transport>`, which monomorphizes to the concrete transport — so the stub reads
// as the natural client, with no hand-rolled envelope.
struct AccountsClient<T: Transport> { transport: T, codec: Codec }

impl AccountsClient<type T> {
	// The client deals only in `WireUser` — it has no `User`, and no `password` field to
	// leak. The round-trip can fail, so the result is wrapped in `Result<_, RpcError>`.
	fun get_user(self, id: i32): Result<Option<WireUser>, RpcError> {
		// `call` writes the envelope in one pass (the argument describes itself
		// into the envelope's serializer — §4.1), awaits the round-trip, and
		// decodes the reply as `Option<WireUser>` — inferred from this return
		// type; infra failures become `Err`.
		call(self.transport, self.codec, "get_user", [|s: Serializer| id.describe(s)])
	}
}

// --- The [service(Client)] paradigm — GENERATED (proposal §4.2) ---------------
//
// `[service(Client)]` generates the plumbing from this struct + its `[rpc]` impl
// methods: `Session::dispatcher(self)` (one route per `[rpc]` method over the §4.1
// `Dispatcher`, handlers capturing the session), the sibling `Client<T: Transport>`
// (the two-signature split — `Session` methods return `T`, `Client` methods return
// `Result<T, RpcError>`; each `[expose]`d field surfaces as a `RemoteSource` mirror),
// and a shared `contract_hash()` on both sides (Q6 v2).

// The per-connection session (Q9): created on connect, captured by the generated
// dispatcher's handlers, so its state persists across the connection's calls. Mutable
// state lives in `Signal`/`Shared` handles — the struct is a lightweight handle, and a
// plain field write would only mutate a closure's *copy* (value semantics); the shared
// cells are what make the state one. `status` is `[expose]`d — the compiler checks it is
// a `Signal` of a Wire type (only observable state can be exposed), and the client
// mirrors it via the reactive protocol (§8); `user_id` is private — it never crosses.
[service(Client)]
struct Session {
	[expose] status: Signal<str>,
	user_id: Shared<Option<i32>>,
}

impl Session {
	// An `[rpc]` method — callable over the wire; the compiler checks its parameters
	// and return are Wire. Verification happens entirely server-side (`Password`
	// never crosses); on success the session records who is logged in and flips the
	// exposed `status` — which the wire turn delivers alongside the reply.
	[rpc]
	fun login(self, username: str, password: str): bool {
		match find_user(username) {
			Some(let user) => {
				if user.password.matches(password) {
					self.user_id.write() = Some(user.id);
					self.status.set("online");
					true
				} else {
					false
				}
			},
			None => false,
		}
	}

	// Manual auth (Q4): ordinary body logic over the state `login` populated — no
	// `[rpc(auth)]` attribute. Unauthenticated is an application-level `None`.
	[rpc]
	fun whoami(self): Option<WireUser> {
		match self.user_id.read() {
			Some(let id) => match lookup_user(id) {
				Some(let user) => Some(user.to_wire()),
				None => None,
			},
			None => None,
		}
	}
}

// The dispatcher and the `Client` sibling that used to be written out here BY HAND are
// now **generated** from the `[service(Client)]` struct above: `Session::dispatcher(self)`
// routes each `[rpc]` method (handlers capture the session), and `Client<T: Transport>`
// carries the `Result`-wrapped requestor methods plus a `RemoteSource` mirror per
// `[expose]`d field. Observers still decode the mirror's JSON-encoded value at the
// concrete site (a typed wrapper is a later refinement).

// --- Wiring + demo -----------------------------------------------------------

fun main() {
	// --- RPC over a request/response transport --------------------------------
	// `accounts_dispatcher()` builds the router; `into_protocol()` wraps it as an `RpcProtocol`
	// (decode envelope → route → encode reply); `local_rpc` mounts that on an in-process
	// transport — the wiring a client stub connects to. Both the RPC and reactive protocols
	// below are `Protocol`s (§2).
	let transport = local_rpc(accounts_dispatcher().into_protocol(json_codec()));
	let client = AccountsClient { transport = transport, codec = json_codec() };

	// A hit (id 1 -> ada), a miss (id 9 -> None, an application-level absence), and a
	// bogus call made directly through the transport (a clean RpcError, no crash).
	show(client.get_user(1));
	show(client.get_user(9));
	show_raw(transport);

	// --- Reactive over a duplex transport -------------------------------------
	reactive_demo();

	// --- Per-connection state + manual auth + an exposed field ----------------
	session_demo();
}

// The reactive north star (proposal §8), by hand: a server holds a `Signal<i32>` and
// exposes it; a client subscribes to the remote handle and sees every change flow over a
// duplex transport. The `Signal`/`Source` never crosses as a value — it is exported as a
// channel id, and its updates cross as `Update` frames.
fun reactive_demo() {
	print("--- reactive: a remote Source<i32> ---");
	let (client_end, server_end) = duplex_pair();

	// Server: a counter, exposed directly — the runtime erases its `i32` to JSON (the
	// generic `expose<T: Json, S: Source<T>>` monomorphizes now, so the app hands over a
	// plain `Signal<i32>`). `channel` is the handle that, in a real system, would cross to
	// the client in an RPC reply; in-process we hand it over.
	let counter: Signal<i32> = Signal::new(0);
	let server = ReactiveServer::new(server_end);
	let channel = server.expose(counter);

	// Client: a remote `Source<str>`; `sub` opens the channel and observes it. Each JSON
	// update is decoded at the concrete site — where `T` is known and monomorphizes.
	let remote = ReactiveClient::new(client_end).source(channel);
	let subscription = remote.sub(|json| {
		let n: i32 = i32::from_json(json);
		print(i"count = {n}");
	});

	// Every lone `set` pushes one `Update` frame — eager, exactly as before batching.
	counter.set(1);
	counter.set(2);

	// A `batch` (std::reactive) coalesces: two writes, ONE `Update` frame — the observer
	// sees only the settled 10; the intermediate 5 never crosses the wire.
	batch(|| {
		counter.set(5);
		counter.set(10);
	});

	// The wire turn (proposal/reactive-batching.md) — the scenario that motivated it: an
	// *RPC call* mutates the signal the client is subscribed to. `local_rpc` handles the
	// request in a `batch`, so the handler's two writes coalesce into one `Update`,
	// delivered in the same turn as the reply. (In-process the update lands first —
	// delivery is synchronous; a buffering transport would flush both together.)
	let dispatcher = Dispatcher::new().on("add", |request| {
		let amount: i32 = arg(request, 0);
		counter.set(counter.get() + amount);   // 13 — the value commits at once...
		counter.set(counter.get() + amount);   // 16 — ...so the second write sees it
		reply(counter.get())
	});
	let rpc_transport = local_rpc(dispatcher.into_protocol(json_codec()));
	let amount = 3;
	let added: Result<i32, RpcError> = call(rpc_transport, json_codec(), "add", [|s: Serializer| amount.describe(s)]);
	match added {
		Ok(let n) => print(i"rpc add -> {n}"),
		Err(let error) => print(i"rpc error: {error.to_json()}"),
	}

	subscription.dispose();   // stop observing; the server's forward is a no-op with no client
	counter.set(99);          // no output — unsubscribed
}

// The session demo — the `[service]` paradigm end-to-end, by hand: per-connection state,
// manual auth, and an exposed signal the client observes.
fun session_demo() {
	print("--- session: the [service(Client)] paradigm, generated ---");

	// Server, on connect: ONE session per connection; the dispatcher's handlers share its
	// handles. The exposed `status` is exported under a channel id (§8) — the id is what
	// a connect handshake would carry; in-process we just hand it over.
	let session = Session { status = Signal::new("offline"), user_id = Shared::new(None) };
	let rpc_transport = local_rpc(session.dispatcher().into_protocol(json_codec()));
	let (client_end, server_end) = duplex_pair();
	let status_channel = ReactiveServer::new(server_end).expose(session.status);

	// Client: what `Client::connect` will assemble — the RPC transport plus a mirror for
	// each exposed field.
	let client = Client {
		transport = rpc_transport,
		codec = json_codec(),
		status = ReactiveClient::new(client_end).source(status_channel),
	};

	// Observe the mirrored session state: "offline" now, "online" once login lands —
	// delivered in the same wire turn as login's reply.
	let watching = client.status.sub(|json| {
		let s: str = str::from_json(json);
		print(i"status = {s}");
	});

	show_whoami(client.whoami());               // manual auth refuses: not logged in
	show_login(client.login("ada", "wrong"));   // bad password -> false, status unchanged
	show_login(client.login("ada", "hunter2")); // -> true; "status = online" in the same turn
	show_whoami(client.whoami());               // the session remembers -> ada (@ada)

	watching.dispose();
}

fun show_login(result: Result<bool, RpcError>) {
	match result {
		Ok(let ok) => print(i"login -> {ok}"),
		Err(let error) => print(i"login rpc error: {error.to_json()}"),
	}
}

fun show_whoami(result: Result<Option<WireUser>, RpcError>) {
	match result {
		Ok(Some(let user)) => print(i"whoami -> {user.username} ({user.handle})"),
		Ok(None) => print("whoami -> not logged in"),
		Err(let error) => print(i"whoami rpc error: {error.to_json()}"),
	}
}

fun show(result: Result<Option<WireUser>, RpcError>) {
	match result {
		Ok(Some(let user)) => print(i"ok: found {user.username} ({user.handle})"),
		Ok(None) => print("ok: no such user"),
		Err(let error) => print(i"rpc error: {error.to_json()}"),
	}
}

// Exercise the error path: invoke a method the dispatcher doesn't know — a clean
// `RpcError::Remote`, no crash.
fun show_raw(transport: LocalTransport) {
	let bogus: Result<i32, RpcError> = call(transport, json_codec(), "delete_everything", []);
	match bogus {
		Ok(let value) => print(i"raw ok: {value}"),
		Err(let error) => print(i"raw error: {error.to_json()}"),
	}
}
