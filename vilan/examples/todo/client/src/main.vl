// The wiring — now ONE generated call (§4.2): `TodoClient::connect` opens the
// WebSocket, enforces the contract hash (a stale bundle is a clean error, not
// mystery decode garbage), and wires the `todos` mirror. The UI never writes
// `items` itself — the server owns the data, and every change (this tab's
// included) arrives over the wire.

import std::print;
import std::reactive::Signal;
import std::json::{ Json, FromJson, json_codec };
import std::result::Result::{ Ok, Err };
import std::ui::mount;
import common::{ Todo, TodoClient };
import pkg::todos::todos;

async fun main() {
	// The local mirror of the server's list — the wire is its only writer.
	let items: Signal<List<Todo>> = Signal::new([]);
	// A relative WebSocket URL resolves against the page's origin (modern
	// browsers); node clients pass an absolute ws:// URL.
	match TodoClient::connect("/", json_codec()) {
		Ok(let client) => {
			mount("app", todos(client, items));
			// The mirror is typed (`RemoteSource<List<Todo>>`): values arrive
			// decoded — the wire's codec is the only (de)serialization.
			let syncing = client.todos.sub(|synced| {
				items.set(synced);
			});
		},
		Err(let error) => print(i"connect failed: {error.to_json()}"),
	}
}
