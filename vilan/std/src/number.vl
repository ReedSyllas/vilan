import pkg::default::Default;
import pkg::compare::PartialEq;
import pkg::operators::{ Add, Sub, Mul, Div, Shl, Shr, BitAnd, BitOr, BitXor };

external struct u32;

impl u32 with Default {
	fun default(): u32 {
		0u32
	}
}

external struct i32;

impl i32 {
	fun diff(self, other: i32): i32 {
		if self > other {
			self - other
		} else {
			other - self
		}
	}

	// Absolute value, exponentiation, and pairwise min/max — thin wrappers over the
	// host `Math` functions (the receiver is passed as the first argument).
	[extern("Math.abs")]
	external fun abs(self): i32;

	[extern("Math.pow")]
	external fun pow(self, exponent: i32): i32;

	[extern("Math.min")]
	external fun min(self, other: i32): i32;

	[extern("Math.max")]
	external fun max(self, other: i32): i32;
}

impl i32 with Default {
	fun default(): i32 {
		0i32
	}
}

external struct f64;

impl f64 {
	// Floating-point math over the host `Math` functions.
	[extern("Math.abs")]
	external fun abs(self): f64;

	[extern("Math.sqrt")]
	external fun sqrt(self): f64;

	[extern("Math.pow")]
	external fun pow(self, exponent: f64): f64;

	[extern("Math.floor")]
	external fun floor(self): f64;

	[extern("Math.ceil")]
	external fun ceil(self): f64;

	[extern("Math.round")]
	external fun round(self): f64;

	[extern("Math.min")]
	external fun min(self, other: f64): f64;

	[extern("Math.max")]
	external fun max(self, other: f64): f64;
}

impl f64 with Default {
	fun default(): f64 {
		0f
	}
}

external struct BigInt;

impl BigInt with Default {
	fun default(): BigInt {
		0n
	}
}

// --- Trait impls for the numeric primitives -----------------------------------
//
// Equality and the operator traits, so generic `T: PartialEq` / `T: Add` / ...
// code (and conditional impls over it) accepts the numeric primitives. Every
// body is the native operator: `+`/`==`/`&` on primitives always lower to
// native JS, so nothing recurses — a body runs only when reached through an
// explicit method call or a generic bound's dispatch; written `a + b` stays
// native and never touches these.

impl i32 with PartialEq {
	fun eq(self, b: i32): bool {
		self == b
	}
}

impl u32 with PartialEq {
	fun eq(self, b: u32): bool {
		self == b
	}
}

impl f64 with PartialEq {
	fun eq(self, b: f64): bool {
		self == b
	}
}

impl BigInt with PartialEq {
	fun eq(self, b: BigInt): bool {
		self == b
	}
}

impl i32 with Add {
	fun add(self, b: i32): i32 {
		self + b
	}
}

impl i32 with Sub {
	fun sub(self, b: i32): i32 {
		self - b
	}
}

impl i32 with Mul {
	fun mul(self, b: i32): i32 {
		self * b
	}
}

impl i32 with Div {
	fun div(self, b: i32): i32 {
		self / b
	}
}

impl u32 with Add {
	fun add(self, b: u32): u32 {
		self + b
	}
}

impl u32 with Sub {
	fun sub(self, b: u32): u32 {
		self - b
	}
}

impl u32 with Mul {
	fun mul(self, b: u32): u32 {
		self * b
	}
}

impl u32 with Div {
	fun div(self, b: u32): u32 {
		self / b
	}
}

impl f64 with Add {
	fun add(self, b: f64): f64 {
		self + b
	}
}

impl f64 with Sub {
	fun sub(self, b: f64): f64 {
		self - b
	}
}

impl f64 with Mul {
	fun mul(self, b: f64): f64 {
		self * b
	}
}

impl f64 with Div {
	fun div(self, b: f64): f64 {
		self / b
	}
}

impl BigInt with Add {
	fun add(self, b: BigInt): BigInt {
		self + b
	}
}

impl BigInt with Sub {
	fun sub(self, b: BigInt): BigInt {
		self - b
	}
}

impl BigInt with Mul {
	fun mul(self, b: BigInt): BigInt {
		self * b
	}
}

impl BigInt with Div {
	fun div(self, b: BigInt): BigInt {
		self / b
	}
}

// The bitwise/shift traits, for the two types the operators are defined on
// (the hex/bitwise slice): `i32` and `u32`. `f64` has no bitwise story and
// `BigInt`'s is unverified — deliberately omitted.

impl i32 with Shl {
	fun shl(self, b: i32): i32 {
		self << b
	}
}

impl i32 with Shr {
	fun shr(self, b: i32): i32 {
		self >> b
	}
}

impl i32 with BitAnd {
	fun bit_and(self, b: i32): i32 {
		self & b
	}
}

impl i32 with BitOr {
	fun bit_or(self, b: i32): i32 {
		self | b
	}
}

impl i32 with BitXor {
	fun bit_xor(self, b: i32): i32 {
		self ^ b
	}
}

impl u32 with Shl {
	fun shl(self, b: u32): u32 {
		self << b
	}
}

impl u32 with Shr {
	fun shr(self, b: u32): u32 {
		self >> b
	}
}

impl u32 with BitAnd {
	fun bit_and(self, b: u32): u32 {
		self & b
	}
}

impl u32 with BitOr {
	fun bit_or(self, b: u32): u32 {
		self | b
	}
}

impl u32 with BitXor {
	fun bit_xor(self, b: u32): u32 {
		self ^ b
	}
}

// --- Parity --------------------------------------------------------------------
//
// Concrete on the integer types: a generic form over `BitAnd` needs a way to
// conjure `one`/`zero` AT the generic type (a `One`/`Zero` seam vilan doesn't
// have), and parity on `f64` is undefined off the integers — so two honest
// one-liners per type beat a new numeric-tower trait.

impl i32 {
	fun is_even(self): bool {
		(self & 1) == 0
	}

	fun is_odd(self): bool {
		(self & 1) == 1
	}
}

impl u32 {
	fun is_even(self): bool {
		(self & 1u32) == 0u32
	}

	fun is_odd(self): bool {
		(self & 1u32) == 1u32
	}
}

// --- The sized numeric family (proposal/numeric-types.md) ---------------------
//
// Nominal widths on the JS backend: every sized integer lowers to a plain JS
// number (i64/u64 exact within ±2^53 — the measured f64-over-BigInt decision,
// §1), `f32` lowers to `f64`. Distinct types, range-checked literals, native
// operators, truncating integer division; width semantics become real on a
// non-JS backend.
//
// GENERATED ONCE by a macro and checked in as plain source: `number.vl` is
// loaded inside every macro world (via std's lib surface), and world files
// must not DISPATCH macros — a world expands with an empty macro scope
// (macro-engine.md §10). The family's shape is pinned by the numeric corpus
// program; regenerate by hand if the surface changes.

external struct i8;

external struct u8;

external struct i16;

external struct u16;

external struct i64;

external struct u64;

external struct f32;

// Conversions (`as_*`, numeric-types.md §4): truncate toward zero, then fold
// into the target's range (two's-complement wrap) — Rust-`as` semantics. All
// arithmetic happens in f64 space: `as_f64` widens (the host `Number` is the
// identity on numbers), the folds below shape the value, and a `label_*`
// extern re-types the result (identity at the JS level).

[extern("Number")]
external fun label_i8(value: f64): i8;

[extern("Number")]
external fun label_u8(value: f64): u8;

[extern("Number")]
external fun label_i16(value: f64): i16;

[extern("Number")]
external fun label_u16(value: f64): u16;

[extern("Number")]
external fun label_i32(value: f64): i32;

[extern("Number")]
external fun label_u32(value: f64): u32;

[extern("Number")]
external fun label_i64(value: f64): i64;

[extern("Number")]
external fun label_u64(value: f64): u64;

[extern("Number")]
external fun label_f32(value: f64): f32;

[extern("Number")]
external fun label_f64(value: f64): f64;

// `value` truncated toward zero, folded into `0 ..= modulus - 1`. (Spelled
// with a truncating quotient — vilan has no `%` operator yet.)
fun fold_unsigned(value: f64, modulus: f64): f64 {
	let truncated = value.trunc();
	let wrapped = truncated - (truncated / modulus).trunc() * modulus;
	if wrapped < 0f {
		wrapped + modulus
	} else {
		wrapped
	}
}

// The signed fold: two's-complement at `modulus`, so `half ..` goes negative.
fun fold_signed(value: f64, modulus: f64, half: f64): f64 {
	let wrapped = fold_unsigned(value, modulus);
	if wrapped >= half {
		wrapped - modulus
	} else {
		wrapped
	}
}

impl f64 {
	// Truncation toward zero — the integer-division primitive (§2) and the
	// first step of every narrowing conversion.
	[extern("Math.trunc")]
	external fun trunc(self): f64;
}

impl i8 {
	[extern("Number")]
	external fun as_f64(self): f64;

	fun as_i8(self): i8 {
		self
	}

	fun as_u8(self): u8 {
		let widened = self.as_f64();
		label_u8(fold_unsigned(widened, 256f))
	}

	fun as_i16(self): i16 {
		let widened = self.as_f64();
		label_i16(fold_signed(widened, 65536f, 32768f))
	}

	fun as_u16(self): u16 {
		let widened = self.as_f64();
		label_u16(fold_unsigned(widened, 65536f))
	}

	fun as_i32(self): i32 {
		let widened = self.as_f64();
		label_i32(fold_signed(widened, 4294967296f, 2147483648f))
	}

	fun as_u32(self): u32 {
		let widened = self.as_f64();
		label_u32(fold_unsigned(widened, 4294967296f))
	}

	fun as_i64(self): i64 {
		let widened = self.as_f64();
		label_i64(widened.trunc())
	}

	fun as_u64(self): u64 {
		let widened = self.as_f64();
		label_u64(widened.trunc())
	}

	fun as_f32(self): f32 {
		let widened = self.as_f64();
		label_f32(widened)
	}
}

