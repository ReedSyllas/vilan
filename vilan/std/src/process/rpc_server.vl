// `std::rpc_server` — the server half of `std::rpc`, mounted on `std::http`:
// where a protocol (a frame handler) meets a real listening socket. The client
// halves live in platform-neutral `std::rpc` (`HttpTransport`, `connect_split`);
// this module is their process-layer counterpart, and the two must agree on the
// wire format (the SSE `data:` framing, the `__conn:<id>` handshake, and the
// `/send?c=<id>` addressing that `SplitDuplex` speaks).
//
// `serve_connected` rides `Server`'s public surface: the SSE stream is a
// STREAMING response (`ResponseBuilder::streaming` — partial writes over a
// held-open response), the binary RPC reply is a bytes body, and the
// WebSocket handshake mounts through `ServerBuilder::on_upgrade`.

import pkg::option::Option::{ Some, None };
import pkg::shared::Shared;
import pkg::reactive::{ batch, turn, FlushPolicy };
import pkg::wire::Frame;
import pkg::bytes::Bytes;
import pkg::json::{ JsonValue, FromJson, has_json_field };
import pkg::ws::{ WsParser, WsEvent, text_frame, binary_frame, pong_frame, close_frame };
import pkg::rpc::{
	RpcProtocol, DuplexEnd, duplex_pair, register_session, drop_session,
	tag_duplex_bytes, tag_rpc_bytes,
};
import pkg::http::{
	NodeRequest, NodeSocket,
	Request, Response, Server,
};

// --- WebSocket handshake (node:crypto) ------------------------------------------

external struct Hash;

[extern("node:crypto", "createHash")]
external fun create_hash(algorithm: str): Hash;

impl Hash {
	[extern(method, "update")]
	external fun update(self, data: str): Hash;

	[extern(method, "digest")]
	external fun digest(self, encoding: str): str;
}

/// RFC 6455 §4.2.2: the `Sec-WebSocket-Accept` proof — base64(SHA-1(key+GUID)).
fun ws_accept_key(key: str): str {
	create_hash("sha1")
		.update(key + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11")
		.digest("base64")
}

// --- Request/response mount ----------------------------------------------------

/// Answer one RPC-over-HTTP request: the POST body is the request frame, and the
/// protocol's reply frame is the response body. The frame is handled in a `batch`
/// — the wire turn (proposal/reactive-batching.md) — so signal writes made while
/// dispatching coalesce. Compose this into a `Server`'s `on_request` alongside
/// other routes, or mount it alone with `serve_rpc`. This mount rides the text
/// `Server` API, so it serves TEXT codecs (JSON); a binary protocol belongs on
/// `serve_connected`'s raw `/rpc` route.
fun rpc_response(protocol: RpcProtocol, request: Request): Response {
	let reply = turn(FlushPolicy::AtEnd, || protocol.respond(Frame::Text(request.body())));
	match reply {
		Frame::Text(let frame) => Response::builder()
			.set_header("Content-Type", "application/json")
			.body(frame)
			.build(),
		Frame::Binary(let frame) => Response::builder()
			.code(500)
			.body("binary reply over a text mount")
			.build(),
	}
}

/// Serve one RPC protocol on `port`: every request is dispatched through it. The
/// client side is `std::rpc`'s `HttpTransport { url = "http://host:port/" }`.
fun serve_rpc(port: i32, protocol: RpcProtocol, on_ready: |Server| void) {
	Server::builder()
		.port(port)
		.on_request(|request| rpc_response(protocol, request))
		.on_start(on_ready)
		.build()
		.start()
}

/// The `Client::connect` server (§4.2): `serve_connected` with the runtime's
/// session registry as its connection lifecycle — every connection gets a
/// reactive session the generated `__attach` route can answer from, disposed
/// on disconnect. Apps needing custom per-connection state (auth identity, an
/// app-written attach) use `serve_connected` directly.
fun serve_service(
	port: i32,
	protocol: RpcProtocol,
	fallback: |Request| Response,
	on_ready: || void,
) {
	serve_connected(
		port,
		protocol,
		|connection, wire| register_session(connection, wire, protocol.codec),
		|connection| drop_session(connection),
		fallback,
		on_ready,
	)
}

// --- Connected server: RPC + a duplex wire per client ---------------------------

/// Live SplitDuplex connections: each client's wire-side `DuplexEnd`, keyed by the
/// connection id announced on its SSE stream.
let connections: Shared<List<(i32, DuplexEnd)>> = Shared::new([]);

/// Connection ids — module-level, one counter for the program.
let next_connection: Shared<i32> = Shared::new(0);

fun fresh_connection(): i32 {
	let id = next_connection.read();
	next_connection.write() = id + 1;
	id
}

/// The full-stack server (the `SplitDuplex` counterpart — proposal §5): one
/// `node:http` server routing
///   `GET  /events`     → a long-lived SSE stream; announces `__conn:<id>`, then
///                        carries server→client frames. Each connection hands the
///                        app a fresh `DuplexEnd` via `on_connect(id, end)` — give
///                        it to a `ReactiveServer` to serve signals over the wire.
///   `POST /send?c=<id>` → one client→server frame for that connection (a turn).
///   `POST /rpc`         → an RPC request frame (a turn).
///   everything else     → `fallback` (static files, 404s).
///
/// A connection ends when its SSE stream closes (tab closed, network gone): the
/// wire is forgotten here, and `on_disconnect(id)` tells the app to drop its own
/// per-connection state (dispose a `ReactiveServer` session, say) — otherwise a
/// long-running server leaks a session per ever-connected client.
fun serve_connected(
	port: i32,
	protocol: RpcProtocol,
	on_connect: |i32, DuplexEnd| void,
	on_disconnect: |i32| void,
	fallback: |Request| Response,
	on_ready: || void,
) {
	Server::builder()
		.port(port)
		.on_request(|request| connected_response(protocol, on_connect, on_disconnect, fallback, request))
		// A WebSocket upgrade is the same connection contract over the true
		// duplex wire (§5): handshake, then the socket joins `connections`
		// exactly like an SSE stream — same `__conn` announcement, same
		// `on_connect`/`on_disconnect`, same app code. Clients pick the
		// transport (`connect_socket` here, `connect_split` for SSE).
		.on_upgrade(|request, socket, head| {
			accept_socket(request, socket, head, protocol, on_connect, on_disconnect);
		})
		.on_start(|server| on_ready())
		.build()
		.start()
}

/// Route one request of the connected server (see `serve_connected`).
fun connected_response(
	protocol: RpcProtocol,
	on_connect: |i32, DuplexEnd| void,
	on_disconnect: |i32| void,
	fallback: |Request| Response,
	request: Request,
): Response {
	let path = request.path();
	if path.starts_with("/events") {
		let id = fresh_connection();
		Response::builder()
			.set_header("Content-Type", "text/event-stream")
			.set_header("Cache-Control", "no-cache")
			.streaming(|stream| {
				stream.send(i"data: __conn:{id}\n\n");
				let (app_end, wire_end) = duplex_pair();
				wire_end.on_frame(|frame| {
					match frame {
						Frame::Text(let body) => stream.send(i"data: {body}\n\n"),
						// SSE can't carry bytes. Unreachable when both sides
						// run one codec: a binary codec's client panics on its
						// first send, before the server ever pushes.
						Frame::Binary(let _bytes) => {},
					}
				});
				connections.write().push((id, wire_end));
				stream.on_close(|| {
					drop_connection(id);
					on_disconnect(id);
				});
				on_connect(id, app_end);
			})
			.build()
	} else if path.starts_with("/send") {
		let content = request.body();
		// A garbled id parses to -1, which matches no connection — the
		// frame is dropped, same as an unknown id.
		let target = connection_id_of(path).parse_i32().unwrap_or(0 - 1);
		for entry in connections.read() {
			let (id, wire) = entry;
			if id == target {
				// the wire turn: the frame's signal writes coalesce
				batch(|| {
					wire.send(Frame::Text(content));
				});
			}
		}
		Response::builder().code(204).body("").build()
	} else if path.starts_with("/rpc") {
		// The body as bytes, no sniffing: the JSON codec's reader accepts a
		// binary frame as UTF-8 (both sides run one codec, Q6).
		let reply = turn(FlushPolicy::AtEnd, || protocol.respond(Frame::Binary(request.bytes())));
		match reply {
			Frame::Text(let frame) => Response::builder()
				.set_header("Content-Type", "application/json")
				.body(frame)
				.build(),
			Frame::Binary(let frame) => Response::builder()
				.set_header("Content-Type", "application/octet-stream")
				.body_bytes(frame)
				.build(),
		}
	} else {
		fallback(request)
	}
}

/// Perform the RFC 6455 handshake and wire the socket into the connection
/// registry. Client→server text frames route by channel prefix (§5's
/// multiplex): `r:<id>:<frame>` is an RPC turn answered on the same socket
/// with the same id, `d:<frame>` is a duplex/reactive wire turn. Pings are
/// answered; close (or a protocol violation) tears the session down like an
/// SSE close.
fun accept_socket(
	request: NodeRequest,
	socket: NodeSocket,
	head: Bytes,
	protocol: RpcProtocol,
	on_connect: |i32, DuplexEnd| void,
	on_disconnect: |i32| void,
) {
	let headers = request.headers();
	if !has_json_field(headers, "sec-websocket-key") {
		socket.destroy();
		ret;
	}
	// Present (checked above) and a string by the WS handshake, so a decode
	// error is impossible; `unwrap_or` keeps the read total.
	let key: str = str::from_json_value(headers.field("sec-websocket-key")).unwrap_or("");
	socket.write_text(
		"HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nSec-WebSocket-Accept: "
			+ ws_accept_key(key)
			+ "\r\n\r\n",
	);
	let id = fresh_connection();
	let (app_end, wire_end) = duplex_pair();
	wire_end.on_frame(|frame| {
		match frame {
			Frame::Text(let body) => socket.write_bytes(text_frame("d:" + body)),
			Frame::Binary(let bytes) => socket.write_bytes(binary_frame(tag_duplex_bytes(bytes))),
		}
	});
	connections.write().push((id, wire_end));
	let closed: Shared<bool> = Shared::new(false);
	let teardown = || {
		if !closed.read() {
			closed.write() = true;
			drop_connection(id);
			on_disconnect(id);
		}
	};
	let parser = WsParser::new();
	let receive = |chunk: Bytes| {
		for event in parser.feed(chunk) {
			match event {
				WsEvent::Text(let frame) => {
					if frame.starts_with("r:") {
						// An RPC turn: answer on this socket with the same id.
						let rest = frame.substring(2, frame.len());
						let parts = rest.split(":");
						let id_text = parts[0];
						let payload = rest.substring(id_text.len() + 1, rest.len());
						let reply = turn(FlushPolicy::AtEnd, || protocol.respond(Frame::Text(payload)));
						match reply {
							Frame::Text(let answer) => {
								socket.write_bytes(text_frame(i"r:{id_text}:{answer}"));
							},
							Frame::Binary(let bytes) => {
								let id = id_text.parse_i32().unwrap_or(0 - 1);
								socket.write_bytes(binary_frame(tag_rpc_bytes(id, bytes)));
							},
						}
					} else if frame.starts_with("d:") {
						// the wire turn: the frame's signal writes coalesce
						batch(|| {
							wire_end.send(Frame::Text(frame.substring(2, frame.len())));
						});
					}
				},
				WsEvent::Ping(let payload) => socket.write_bytes(pong_frame(payload)),
				WsEvent::Closed => {
					socket.write_bytes(close_frame());
					socket.destroy();
				},
				// The byte lanes (§5's multiplex, tag form): `0x64` is a duplex
				// frame, `0x72` + 4-byte LE id is an RPC turn answered in kind.
				WsEvent::Binary(let bytes) => {
					if bytes.len() > 0 && bytes.get(0) == 0x64 {
						// the wire turn: the frame's signal writes coalesce
						batch(|| {
							wire_end.send(Frame::Binary(bytes.slice(1, bytes.len())));
						});
					} else if bytes.len() >= 5 && bytes.get(0) == 0x72 {
						let id = bytes.get(1)
							| bytes.get(2) << 8
							| bytes.get(3) << 16
							| bytes.get(4) << 24;
						let payload = bytes.slice(5, bytes.len());
						let reply = turn(FlushPolicy::AtEnd, || protocol.respond(Frame::Binary(payload)));
						match reply {
							Frame::Binary(let answer) => {
								socket.write_bytes(binary_frame(tag_rpc_bytes(id, answer)));
							},
							Frame::Text(let answer) => {
								socket.write_bytes(text_frame(i"r:{id}:{answer}"));
							},
						}
					}
				},
			}
		}
	};
	if head.len() > 0 {
		receive(head);
	}
	socket.on_bytes("data", receive);
	socket.on_signal("close", teardown);
	socket.on_signal("error", || socket.destroy());
	socket.write_bytes(text_frame(i"__conn:{id}"));
	on_connect(id, app_end);
}

/// Forget a closed connection's wire (frames already in flight to it are
/// silently dropped by the host — see `NodeResponse.write`).
fun drop_connection(target: i32) {
	mut kept: List<(i32, DuplexEnd)> = [];
	for entry in connections.read() {
		let (id, wire) = entry;
		if id != target {
			kept.push((id, wire));
		}
	}
	connections.write() = kept;
}

/// `/send?c=<id>` → `<id>`.
fun connection_id_of(path: str): str {
	let parts = path.split("c=");
	parts[parts.len() - 1]
}
