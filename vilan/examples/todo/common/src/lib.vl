// `common` — the shared vocabulary of the to-do app: just the wire type now.
// `[derive(Wire)]` gives `Todo` its codec and proves every field is
// wire-safe. The service itself lives with its resources in
// `server/src/store.vl` (platform coloring lets the browser build import its
// generated client from there without compiling the server-only bodies);
// this library keeps the payload types both sides speak.

[derive(Wire, PartialEq)]
struct Todo {
	id: i32,
	label: str,
	done: bool,
}
