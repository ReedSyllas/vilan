{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vilan",
  "scopeName": "source.vilan",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.vilan",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vilan",
          "begin": "i?\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vilan",
              "match": "\\\\."
            },
            {
              "name": "meta.template.expression.vilan",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.template-expression.begin.vilan" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.template-expression.end.vilan" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.vilan",
          "match": "\\b[0-9]+(\\.[0-9]+)?[a-zA-Z_]*\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.vilan",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vilan",
          "match": "\\b(if|else|match|for|in|is|jump|ret|with|await)\\b"
        },
        {
          "name": "storage.type.vilan",
          "match": "\\b(fun|struct|enum|impl|trait|import|type|mod|async)\\b"
        },
        {
          "name": "storage.modifier.vilan",
          "match": "\\b(let|mut|own|external|export|use)\\b"
        },
        {
          "name": "constant.language.vilan",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.vilan",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.vilan",
          "match": "\\b[a-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.vilan",
          "match": "(::|=>|==|!=|\\+=|-=|\\*=|/=|&&|\\|\\||&mut|[-:!*/+=|&<>])"
        }
      ]
    }
  }
}
