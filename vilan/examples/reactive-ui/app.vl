// app.vl — the client entry. Components are ordinary functions returning a
// `View`, so an app is just composition: build the views and `mount` them.
//
// Both components build and run: the counter, and the todo list (`todos.vl`) now
// that `combine` (variadic generics), `bind_each`, and `show` are implemented.

import std::ui::mount;
import pkg::counter::counter;
import pkg::todos::todos;

fun main() {
	mount("counter", counter());
	mount("todos", todos());
}
