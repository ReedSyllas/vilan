trait Default {
	fun default(): Self;
}

// Default values for the core scalar primitives that don't define one in their
// own module (numbers do, in `number.vl`). An empty string and `false` mirror
// the zero/identity each takes.
impl str with Default {
	fun default(): str {
		""
	}
}

impl bool with Default {
	fun default(): bool {
		false
	}
}

// The `Default` derive: a prelude macro (this module is always loaded).

macro fun Default(item: Item): Source {
	import macro_std::source;
	import macro_std::meta::{ Item, Source };
	import macro_std::option::Option::{ self, Some, None };
	import macro_std::build::{ impl_of, fun_of, init_of };

	if item.as_struct() is Some(let target) {
		// `{ a = i32::default(), b = Point::default() }`.
		mut literal = init_of(target.name);
		for field in target.fields {
			literal = literal.field(field.name, i"{field.type_.render()}::default()");
		}
		let constructor = fun_of("default")
			.returns(target.name)
			.expr(literal.render());
		ret source("import std::default::Default;\n"
			+ impl_of(target.name).implements("Default").method(constructor).render());
	}
	// An enum has no unambiguous default variant — nothing, like the Rust
	// generator.
	source("")
}
