// std::math (backlog K2): constants, the moved Ord free functions, the f64
// method family, sized-type parity, and truncated `rem`. Every printed value
// is exactly representable, so the output is deterministic.
import std::print;
import std::math::{ PI, TAU, E, EPSILON, INFINITY, NAN, min, max, minmax };

fun main() {
	// Constants.
	print(PI);
	print(TAU == PI * 2f);
	print(E > 2.718f && E < 2.719f);
	print(EPSILON == 2f.pow(0f - 52f));
	print(INFINITY > 0f && INFINITY.is_infinite());
	print(NAN.is_nan());

	// Moved free functions (methods stay on Ord).
	print(min(3, 9));
	print(max("ant", "bee"));
	let (low, high) = minmax(9, 3);
	print(i"{low} {high}");

	// Trigonometry at exact points.
	print(0f.sin());
	print(0f.cos());
	print(0f.atan2(1f));
	print(180f.to_radians() == PI);
	print(PI.to_degrees());

	// Exponentials and logarithms.
	print(0f.exp());
	print(1f.ln());
	print(8f.log2());
	print(1000f.log10());
	print(27f.cbrt());
	print(3f.hypot(4f));

	// Shape and structure.
	print((0f - 5f).sign());
	print(1.5f.fract());
	print(0f.lerp(10f, 0.5f));
	print(7.5f.rem(2f));

	// Classification.
	print(1.5f.is_finite());
	print(INFINITY.is_finite());

	// Integer families: abs (signed), pow/min/max/rem (all).
	print((0i8 - 5i8).abs());
	print(3i16.pow(2i16));
	print(200u16.min(90u16));
	print(7u64.max(9u64));
	print(7.rem(3));
	print((0 - 7).rem(3));
	print(250u8.rem(7u8));
	print(9i64.rem(4i64));
	print(3000000000u32.rem(7u32));

	// f32 family.
	print(2f32.pow(3f32));
	print(2.25f32.sqrt());
	print((0f32 - 1.5f32).abs());
}
main();
