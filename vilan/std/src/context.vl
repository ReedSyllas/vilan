// `std::context` — a dynamically-scoped value, like a compile-time
// `AsyncLocalStorage`. `Context::new()` creates a context bound at module
// scope; `run(value, body)` makes `value` the context's value for the dynamic
// extent of `body`; `get()` reads the value established by the nearest
// enclosing `run`. The compiler threads the value as a hidden parameter through
// every function that transitively calls `get()` (and captures it into
// closures created within a `run`), so there is no runtime storage and it works
// in the browser.
//
// `Context`, `new`, `run`, and `get` are intrinsics: the `context` threading
// pass rewrites their call sites away, so these signatures exist only to type
// check user code. `Context<T>`'s value type `T` is inferred from the first
// `run` (`count.run(0, ..)` makes it `Context<i32>`), exactly as `List<T>`'s
// element type is inferred from `push`.

import pkg::option::Option;

external struct Context<T>;

impl Context<type T> {
	external fun new(): Context<T>;

	/// `run` yields its body's value (like `batch`): the threading pass
	/// rewrites the call to `body(value)`, whose result this is.
	external fun run<U>(self, value: T, body: || U): U;

	external fun get(self): T;

	/// The possibly-established read: `Some(value)` under an enclosing `run`,
	/// `None` otherwise — no coverage fence. Code reachable only through
	/// `get_safe` carries the value as an `Option<T>` hidden parameter
	/// (strict `get` regions keep the bare `T` flavor and the static check);
	/// the covered→safe boundary `Some`-wraps, and safe-only roots receive
	/// `None` (proposal/reactive-turns.md §5.1, ambient-owner.md §2.1).
	external fun get_safe(self): Option<T>;
}
