// `std::fetch` — HTTP requests over the host `fetch` global, which exists in both
// the browser and Node (18+), so this is a core (universal) module: a browser
// client can call its server's API routes, and a Node program can call out too.
//
// `fetch(url)` is a GET shorthand. For another method, a request body, or headers,
// build a request with `get`/`post`, chain `.header(..)`, and `.send()` it.
//
// `fetch`/`send` and `Response::text` are async (the host returns promises), so calls
// to them are implicitly awaited.

import pkg::bytes::{ Bytes, ByteBuffer, bytes_of_buffer };

external struct Response;

[extern("fetch")]
async external fun fetch(url: str): Response;

impl Response {
	// The HTTP status code (e.g. 200).
	[extern(get, "status")]
	external fun status(self): i32;

	// The response body as text. Async (it awaits the host `Response.text()`).
	[extern(method, "text")]
	async external fun text(self): str;

	// The raw response body (`Response.arrayBuffer()`), for binary frames.
	[extern(method, "arrayBuffer")]
	async external fun raw_body(self): ByteBuffer;

	// The response body as bytes.
	fun bytes(self): Bytes {
		bytes_of_buffer(self.raw_body())
	}
}

// --- Streaming responses -------------------------------------------------------

// For long-lived responses — an SSE event stream, say — where `text()` would
// never resolve: read the body chunk by chunk (`response.body.getReader()`),
// decoding each with a `std::bytes` `TextDecoder`. Works in the browser and
// node/deno/bun.

// The host `ReadableStream` (a `Response.body`).
external struct BodyStream;

// A `ReadableStreamDefaultReader` over it.
external struct BodyReader;

// One `reader.read()` result: `{ done, value }`.
external struct ChunkResult;

impl Response {
	[extern(get, "body")]
	external fun body_stream(self): BodyStream;
}

impl BodyStream {
	[extern(method, "getReader")]
	external fun reader(self): BodyReader;
}

impl BodyReader {
	// Await the next chunk; `finished()` turns true once the stream closes.
	[extern(method, "read")]
	async external fun read_chunk(self): ChunkResult;
}

impl ChunkResult {
	[extern(get, "done")]
	external fun finished(self): bool;

	[extern(get, "value")]
	external fun payload(self): Bytes;
}

// --- Configurable requests ---------------------------------------------------

// One request header. A two-field struct lowers to the `[name, value]` array that
// the host `fetch` accepts as a headers entry, so `List<Header>` is a valid
// `HeadersInit` with no conversion.
struct Header {
	name: str,
	value: str,
}

// The host `fetch` init object — `{ method, headers, body }` — built up via setters.
// It's an opaque host value (like a DOM node), not a vilan struct.
external struct RequestInit;

// `Object()` returns a fresh empty `{}` to fill in.
[extern("Object")]
external fun new_request_init(): RequestInit;

impl RequestInit {
	[extern(set, "method")]
	external fun set_method(self, value: str);

	[extern(set, "body")]
	external fun set_body(self, value: str);

	// A binary request body (the host accepts a Uint8Array directly).
	[extern(set, "body")]
	external fun set_body_bytes(self, value: Bytes);

	[extern(set, "headers")]
	external fun set_headers(self, value: List<Header>);
}

[extern("fetch")]
async external fun fetch_with(url: str, options: RequestInit): Response;

// A request being built: its method + URL, an optional body, and headers.
struct Request {
	url: str,
	method: str,
	body: str,
	headers: List<Header>,
}

// Start a GET request.
fun get(url: str): Request {
	Request { url = url, method = "GET", body = "", headers = [] }
}

// Start a POST request carrying `body`.
fun post(url: str, body: str): Request {
	Request { url = url, method = "POST", body = body, headers = [] }
}

// A one-shot binary POST (no header chaining): send `body` as bytes and await
// the response — the byte-capable leg of the RPC transport (§6.2).
fun post_bytes(url: str, body: Bytes): Response {
	let options = new_request_init();
	options.set_method("POST");
	options.set_body_bytes(body);
	fetch_with(url, options)
}

impl Request {
	// Add a request header (e.g. `Content-Type`, `Authorization`).
	fun header(own self, name: str, value: str): Request {
		self.headers.push(Header { name = name, value = value });
		self
	}

	// Send the request and await the response. GET can't carry a body, so the body
	// is attached only for other methods.
	fun send(self): Response {
		let options = new_request_init();
		options.set_method(self.method);
		options.set_headers(self.headers);
		if self.method != "GET" {
			options.set_body(self.body);
		}
		fetch_with(self.url, options)
	}
}
