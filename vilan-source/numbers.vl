
fun main() {
	let v: u32 = 10;
	let v: u32 = 10u;
	let v: u32 = 10u32;
	
	let v: i32 = 10;
	let v: i32 = 10i;
	let v: i32 = 10i32;
	let v: i32 = -10i32;
	
	let v: f64 = 10;
	let v: f64 = 10f;
	let v: f64 = 10.175f;
	let v: f64 = 10.175f64;
	let v: f64 = -10.175f64;
	
	let v: BigInt = 1000;
	let v: BigInt = 1000n;
	let v: BigInt = -1000n;
}
