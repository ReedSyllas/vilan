impl f64 with PartialOrd {
	// NaN-honest: unordered comparisons yield `None`. The floats are
	// deliberately NOT `Ord` — a total order over NaN would be a lie; use
	// the `Math`-backed `min`/`max` METHODS for float pairs.
	fun partial_compare(self, b: f64): Option<Ordering> {
		if self < b {
			Some(Ordering::Less)
		} else {
			if self > b {
				Some(Ordering::Greater)
			} else {
				if self == b {
					Some(Ordering::Equal)
				} else {
					None
				}
			}
		}
	}
}

impl f32 with PartialOrd {
	// NaN-honest: unordered comparisons yield `None`. The floats are
	// deliberately NOT `Ord` — a total order over NaN would be a lie; use
	// the `Math`-backed `min`/`max` METHODS for float pairs.
	fun partial_compare(self, b: f32): Option<Ordering> {
		if self < b {
			Some(Ordering::Less)
		} else {
			if self > b {
				Some(Ordering::Greater)
			} else {
				if self == b {
					Some(Ordering::Equal)
				} else {
					None
				}
			}
		}
	}
}

// --- Trait impls for the numeric primitives -----------------------------------
//
// Equality and the operator traits, so generic `T: PartialEq` / `T: Add` / ...
// code (and conditional impls over it) accepts the numeric primitives. Every
// body is the native operator: `+`/`==`/`&` on primitives always lower to
// native JS, so nothing recurses — a body runs only when reached through an
// explicit method call or a generic bound's dispatch; written `a + b` stays
// native and never touches these.

impl i32 with PartialEq {
	fun eq(self, b: i32): bool {
		self == b
	}
}

impl u32 with PartialEq {
	fun eq(self, b: u32): bool {
		self == b
	}
}

impl f64 with PartialEq {
	fun eq(self, b: f64): bool {
		self == b
	}
}

impl BigInt with PartialEq {
	fun eq(self, b: BigInt): bool {
		self == b
	}
}

impl i32 with Add {
	fun add(self, b: i32): i32 {
		self + b
	}
}

impl i32 with Sub {
	fun sub(self, b: i32): i32 {
		self - b
	}
}

impl i32 with Mul {
	fun mul(self, b: i32): i32 {
		self * b
	}
}

impl i32 with Div {
	fun div(self, b: i32): i32 {
		self / b
	}
}

impl u32 with Add {
	fun add(self, b: u32): u32 {
		self + b
	}
}

impl u32 with Sub {
	fun sub(self, b: u32): u32 {
		self - b
	}
}

impl u32 with Mul {
	fun mul(self, b: u32): u32 {
		self * b
	}
}

impl u32 with Div {
	fun div(self, b: u32): u32 {
		self / b
	}
}

impl f64 with Add {
	fun add(self, b: f64): f64 {
		self + b
	}
}

impl f64 with Sub {
	fun sub(self, b: f64): f64 {
		self - b
	}
}

impl f64 with Mul {
	fun mul(self, b: f64): f64 {
		self * b
	}
}

impl f64 with Div {
	fun div(self, b: f64): f64 {
		self / b
	}
}

impl BigInt with Add {
	fun add(self, b: BigInt): BigInt {
		self + b
	}
}

impl BigInt with Sub {
	fun sub(self, b: BigInt): BigInt {
		self - b
	}
}

impl BigInt with Mul {
