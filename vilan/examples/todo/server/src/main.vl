// The server: boots the one authoritative `TodoStore` (which owns its own
// persistence — see `store.vl`), serves the browser bundle, and mounts the
// store's generated dispatcher on a connected server
// (`std::rpc_server::serve_connected`) — `POST /rpc` carries the client's
// calls, and each session's SSE stream (`GET /events`) carries the list's
// changes out to every subscribed tab.

import std::print;
import std::json::json_codec;
import std::http::Response;
import std::rpc_server::serve_service;
import std::fs;
import pkg::store::boot;

async fun main() {
	// Read the browser bundle once (`vilan build`/`run` writes it to
	// `dist/client.js`, and the server runs from the project root).
	let client_js = fs::read_file_to_str("dist/client.js");
	// The compiled stylesheet the client's `const` styles emitted at build
	// time (proposal/ui-styling.md) — served like the bundle it belongs to.
	let client_css = fs::read_file_to_str("dist/client.css");

	let app_html = fs::read_file_to_str("server/src/app.html");

	// Reload, seed ids, subscribe persistence — the store's own lifecycle.
	let store = boot();

	serve_service(59386, store.dispatcher().into_protocol(json_codec()), |request| {
		match request.path() {
			"/client.js" => Response::builder().set_header("Content-Type", "text/javascript").body(client_js).build(),
			"/client.css" => Response::builder().set_header("Content-Type", "text/css").body(client_css).build(),
			_ => Response::builder().set_header("Content-Type", "text/html").body(app_html).build(),
		}
	}, || print("todo server: http://localhost:59386/ — open it in two tabs"));
}

