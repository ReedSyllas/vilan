import std::print;

struct Point {
	x: f64,
	y: f64,
}

impl Point {
	fun new(x: f64, y: f64) {
		Point { x, y }
	}
	
	fun double(&mut self) {
		self.x *= 2;
		self.y *= 2;
	}
	
	fun scale(self, factor: f64): Point {
		Point {
			x = self.x * factor,
			y = self.y * factor,
		}
	}
}

fun main() {
	let a = Point::new(6, 5);
	print(a.scale(5));
}
