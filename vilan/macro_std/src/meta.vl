import std::option::Option::{ self, Some, None };

// The compiler-interaction surface (proposal/macro-engine.md §3): the types a
// `macro fun` receives and returns. These are ordinary vilan values — the
// compiler constructs them from its AST at expansion time and consumes the
// returned `Source` back. Shapes are v1: syntactic, not semantic (a `TypeExpr`
// is a *written* type, renderable back to text; nothing here is resolved).

// Generated vilan source text, the output of every macro. Built with
// `macro_std::source(..)`; the compiler parses it in place of the invocation.
export struct Source {
	text: str,
}

// A written type: its head name and its written arguments, renderable back to
// source text (`List<i32>` is `TypeExpr { name = "List", arguments = [i32] }`).
export struct TypeExpr {
	name: str,
	arguments: List<TypeExpr>,
}

impl TypeExpr {
	fun render(self): str {
		if self.arguments.len() == 0 {
			self.name
		} else {
			mut rendered = i"{self.name}<";
			mut first = true;
			for argument in &self.arguments {
				if first {
					first = false;
				} else {
					rendered = rendered + ", ";
				}
				rendered = rendered + argument.render();
			}
			rendered + ">"
		}
	}
}

// One struct field: its name, its written type, and whether it is marked
// `[expose]` (a service-surface field, transport-rpc.md §4.2).
export struct Field {
	name: str,
	type_: TypeExpr,
	exposed: bool,
}

export struct StructItem {
	name: str,
	fields: List<Field>,
}

// One enum variant: its name and its payload types (empty for a bare variant).
export struct Variant {
	name: str,
	payload: List<TypeExpr>,
}

export struct EnumItem {
	name: str,
	variants: List<Variant>,
}

export struct FunctionItem {
	name: str,
	parameters: List<Field>,
	return_type: TypeExpr,
}

// A `[service(Client)]` struct with its same-module `[rpc]` surface gathered
// by the compiler: the service name, the resolved client name (given or
// `{name}Client`), the struct's fields (exposure flags included), and the
// `[rpc]` methods from this module's inherent impls (each with all written
// parameters — `self` included; generators skip it by name).
export struct ServiceItem {
	name: str,
	client_name: str,
	fields: List<Field>,
	methods: List<FunctionItem>,
}

// The item a macro attribute annotates — what `[derive(X)]`-style macros
// receive. The `as_struct`/`as_enum` accessors give the common shapes back as
// options, so a struct-only macro can `item.as_struct()!`.
export enum Item {
	Struct(StructItem),
	Enum(EnumItem),
	Function(FunctionItem),
	Service(ServiceItem),
}

impl Item {
	fun as_struct(self): Option<StructItem> {
		match self {
			Item::Struct(let item) => Option::Some(item),
			_ => Option::None,
		}
	}

	fun as_enum(self): Option<EnumItem> {
		match self {
			Item::Enum(let item) => Option::Some(item),
			_ => Option::None,
		}
	}

	fun as_function(self): Option<FunctionItem> {
		match self {
			Item::Function(let item) => Option::Some(item),
			_ => Option::None,
		}
	}

	fun as_service(self): Option<ServiceItem> {
		match self {
			Item::Service(let item) => Option::Some(item),
			_ => Option::None,
		}
	}
}

// An invocation's arguments, as written: `macro unroll(4, |i| body)` delivers
// the raw argument texts, with typed accessors over the syntactic capture
// (macro-engine.md §3, the construction API step 1) — full `Expr` reflection
// is the recorded follow-up.
export struct Arguments {
	values: List<str>,
}

impl Arguments {
	fun len(self): i32 {
		self.values.len()
	}

	// The argument's raw source text.
	fun get(self, index: i32): Option<str> {
		self.values.get(index)
	}

	// The argument as an integer literal.
	fun as_i32(self, index: i32): Option<i32> {
		match self.values.get(index) {
			Some(let text) => text.parse_i32(),
			None => None,
		}
	}

	// The argument as a string literal's contents (the quotes stripped;
	// escapes left as written).
	fun as_str_literal(self, index: i32): Option<str> {
		match self.values.get(index) {
			Some(let text) => {
				if text.len() >= 2 && text.starts_with("\"") && text.ends_with("\"") {
					Some(text.substring(1, text.len() - 1))
				} else {
					None
				}
			},
			None => None,
		}
	}

	// The argument as a bare identifier: non-empty, no digit first, none of
	// the common expression punctuation. (Syntactic v1 — `Expr` reflection
	// replaces this.)
	fun as_identifier(self, index: i32): Option<str> {
		match self.values.get(index) {
			Some(let text) => {
				if text.len() == 0 {
					ret None;
				}
				if "0123456789".contains(text.substring(0, 1)) {
					ret None;
				}
				if text.contains(" ") || text.contains("\"") || text.contains("(")
					|| text.contains(".") || text.contains("+") || text.contains("-")
					|| text.contains("|") || text.contains(":") {
					ret None;
				}
				Some(text)
			},
			None => None,
		}
	}
}
