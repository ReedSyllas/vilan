// `std::debug` — `[derive(Debug)]` synthesizes `debug(self): str`, a developer
// representation `Type { field = value, … }` built from the fields. Scalars
// format via the host `JSON.stringify` (numbers/bools raw, strings quoted and
// escaped); nested derived structs recurse through their own `debug`.

trait Debug {
	fun debug(self): str;
}

impl str with Debug {
	[extern("JSON.stringify")]
	external fun debug(self): str;
}

impl i32 with Debug {
	[extern("JSON.stringify")]
	external fun debug(self): str;
}

impl u32 with Debug {
	[extern("JSON.stringify")]
	external fun debug(self): str;
}

impl f64 with Debug {
	[extern("JSON.stringify")]
	external fun debug(self): str;
}

impl bool with Debug {
	[extern("JSON.stringify")]
	external fun debug(self): str;
}

// The `Debug` derive: a prelude macro (this module is always loaded).

macro fun Debug(item: Item): Source {
	import macro_std::option::Option::{ self, Some, None };
	import macro_std::build::{ impl_of, fun_of, match_of, quote, join };

	// Debug output glues text fragments around each `.debug()` call, so the
	// pieces join on ` + ", " + ` — a quoted separator between quoted labels.
	let glued_comma = " + " + quote(", ") + " + ";

	if item.as_struct() is Some(let target) {
		// `"T { " + "a = " + self.a.debug() + ", " + … + " }"`; a
		// field-less struct is just its name.
		mut body = "";
		if target.fields.len() == 0 {
			body = quote(target.name);
		} else {
			mut parts: List<str> = [];
			for field in target.fields {
				parts.push(quote(i"{field.name} = ") + i" + self.{field.name}.debug()");
			}
			body = quote(i"{target.name} \{ ") + " + " + join(parts, glued_comma) + " + " + quote(" }");
		}
		let printer = fun_of("debug")
			.parameter("self")
			.returns("str")
			.expr(body);
		ret source("import std::debug::Debug;\n"
			+ impl_of(target.name).implements("Debug").method(printer).render());
	}
	if item.as_enum() is Some(let target) {
		// `match self { E::V(let p0,..) => "V(" + p0.debug() + ", " + .. +
		// ")", E::W => "W" }`.
		mut arms = match_of("self");
		for variant in target.variants {
			let arity = variant.payload.len();
			if arity == 0 {
				arms = arms.arm(i"{target.name}::{variant.name}", quote(variant.name));
			} else {
				mut binds: List<str> = [];
				mut parts: List<str> = [];
				mut index = 0;
				for index < arity {
					binds.push(i"let p{index}");
					parts.push(i"p{index}.debug()");
					index = index + 1;
				}
				let bind_pattern = join(binds, ", ");
				let rendering = quote(i"{variant.name}(") + " + " + join(parts, glued_comma) + " + " + quote(")");
				arms = arms.arm(i"{target.name}::{variant.name}({bind_pattern})", rendering);
			}
		}
		let printer = fun_of("debug")
			.parameter("self")
			.returns("str")
			.expr(arms.render());
		ret source("import std::debug::Debug;\n"
			+ impl_of(target.name).implements("Debug").method(printer).render());
	}
	source("")
}

