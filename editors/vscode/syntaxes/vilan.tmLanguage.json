{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vilan",
  "scopeName": "source.vilan",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#function-definition" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.vilan",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vilan",
          "begin": "(i)?(\")",
          "beginCaptures": {
            "1": { "name": "storage.type.string.vilan" },
            "2": { "name": "punctuation.definition.string.begin.vilan" }
          },
          "end": "(\")",
          "endCaptures": {
            "1": { "name": "punctuation.definition.string.end.vilan" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.vilan",
              "match": "\\\\."
            },
            {
              "comment": "Interpolation `{expr}` in an `i\"...\"` string.",
              "name": "meta.template.expression.vilan",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.template-expression.begin.vilan" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.template-expression.end.vilan" }
              },
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "comment": "Decimal literal with an optional type suffix (`42u32`, `3.5f`, `0n`).",
          "name": "constant.numeric.vilan",
          "match": "\\b[0-9]+(\\.[0-9]+)?[A-Za-z_]*\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "comment": "Bracket attributes: the built-in markers anywhere, plus GENERIC macro attributes `[name]` / `[name(args)]` at the start of a line (an expression's list literal never opens an item line, which keeps `[1, 2]` and `[x]` out).",
          "name": "meta.attribute.vilan",
          "begin": "(\\[)(?=\\s*(extern|derive|must_use|service|rpc|expose|trait_only|doc)\\b)|^\\s*(\\[)(?=\\s*[A-Za-z_][A-Za-z0-9_]*\\s*[\\(\\]])",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.attribute.begin.vilan" },
            "3": { "name": "punctuation.definition.attribute.begin.vilan" }
          },
          "end": "(\\])",
          "endCaptures": {
            "1": { "name": "punctuation.definition.attribute.end.vilan" }
          },
          "patterns": [
            {
              "match": "\\b(extern|derive|must_use|service|rpc|expose|trait_only|doc)\\b",
              "name": "keyword.other.attribute.vilan"
            },
            {
              "comment": "The `method`/`get`/`set` words inside `[extern(..)]`.",
              "match": "\\b(method|get|set)\\b",
              "name": "support.constant.attribute.vilan"
            },
            { "include": "#strings" },
            { "include": "#types" },
            {
              "comment": "A macro name — the attribute itself, or a lowercase derive name like `[derive(derive_display)]` (capitalized ones color as types above).",
              "match": "\\b[a-z_][A-Za-z0-9_]*\\b",
              "name": "entity.name.function.macro.vilan"
            }
          ]
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "comment": "`macro fun name` — a macro definition (macro-engine.md §3).",
          "match": "\\b(macro)\\s+(fun)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.macro.vilan" },
            "2": { "name": "storage.type.function.vilan" },
            "3": { "name": "entity.name.function.macro.vilan" }
          }
        },
        {
          "comment": "`macro name(..)` — a macro invocation (splice site).",
          "match": "\\b(macro)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.control.macro.vilan" },
            "2": { "name": "entity.name.function.macro.vilan" }
          }
        },
        {
          "comment": "`fun name` — the name in a function/method declaration.",
          "match": "\\b(fun)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.vilan" },
            "2": { "name": "entity.name.function.vilan" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vilan",
          "match": "\\b(if|else|match|for|in|is|jump|ret|await)\\b"
        },
        {
          "name": "keyword.control.import.vilan",
          "match": "\\b(import|use)\\b"
        },
        {
          "comment": "Declaration keywords that introduce a named item.",
          "name": "storage.type.vilan",
          "match": "\\b(fun|struct|enum|impl|trait|type|mod|macro)\\b"
        },
        {
          "name": "storage.modifier.vilan",
          "match": "\\b(let|mut|own|external|export|async)\\b"
        },
        {
          "comment": "`with` (trait impl / bound) and the `borrows` return clause.",
          "name": "keyword.other.vilan",
          "match": "\\b(with|borrows)\\b"
        },
        {
          "name": "constant.language.vilan",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "variable.language.self.vilan",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "comment": "Primitive types.",
          "name": "support.type.primitive.vilan",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|str|bool|void|any)\\b"
        },
        {
          "comment": "User types / variants — PascalCase identifiers (and `Self`).",
          "name": "entity.name.type.vilan",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "comment": "A lowercase identifier immediately followed by `(` is a call.",
          "name": "entity.name.function.vilan",
          "match": "[a-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "comment": "Multi-char operators first (`&mut`, `||`, `::`, `=>`, compound assigns, comparisons), then single-char.",
          "name": "keyword.operator.vilan",
          "match": "&mut|\\|\\||&&|::|=>|==|!=|<=|>=|\\+=|-=|\\*=|/=|[-+*/=<>!&|]"
        }
      ]
    }
  }
}
