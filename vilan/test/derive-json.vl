import std::print;

// `@derive(Json)` synthesizes both directions — `to_json` (a faithful JSON object
// with real field names, which a bare `JSON.stringify` of a vilan struct can't
// produce) and `from_json` (rebuilding the struct from that object). Scalars
// serialize via the host `JSON.stringify` and coerce back via `Number`/`String`/
// `Boolean`; nested derived structs recurse in both directions.
@derive(Json)
struct Point {
	x: i32,
	y: i32,
}

@derive(Json)
struct Person {
	name: str,
	age: i32,
	active: bool,
	home: Point,
}

fun main() {
	let p = Point { x = 1, y = 2 };
	print(p.to_json()); // {"x":1,"y":2}

	let person = Person {
		name = "Ada \"A\"",
		age = 36,
		active = true,
		home = Point { x = 3, y = 4 },
	};
	// Escaped string, bool, and a nested object — all faithful.
	let text = person.to_json();
	print(text);

	// `from_json` parses it back into a `Person`; the nested `Point` and every
	// scalar survive, so re-serializing reproduces the original document.
	let back = Person::from_json(text);
	print(back.to_json() == text); // true
	print(back.home.y); // 4
	print(back.name); // Ada "A"
}
