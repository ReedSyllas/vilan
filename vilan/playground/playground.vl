import std::{ print, random };

fun main() {
	let low = 1u;
	let high = 10u;
	
	mut distribution: List<u32> = [];
	
	mut i = 0;
	for i < low.diff(high) {
		distribution.push(0);
		i += 1;
	}
	
	mut iteration = 0;
	for iteration < 1000 {
		let number = random::range(low, high);
		*distribution.at(number) += 1;
	}
	
	print(distribution);
}
