	fun rem(self, m: u8): u8 {
		self - self / m * m
	}

	[extern("Number")]
	external fun as_f64(self): f64;

	fun as_i8(self): i8 {
		let widened = self.as_f64();
		label_i8(fold_signed(widened, 256f, 128f))
	}

	fun as_u8(self): u8 {
		self
	}

	fun as_i16(self): i16 {
		let widened = self.as_f64();
		label_i16(fold_signed(widened, 65536f, 32768f))
	}

	fun as_u16(self): u16 {
		let widened = self.as_f64();
		label_u16(fold_unsigned(widened, 65536f))
	}

	fun as_i32(self): i32 {
		let widened = self.as_f64();
		label_i32(fold_signed(widened, 4294967296f, 2147483648f))
	}

	fun as_u32(self): u32 {
		let widened = self.as_f64();
		label_u32(fold_unsigned(widened, 4294967296f))
	}

	fun as_i64(self): i64 {
		let widened = self.as_f64();
		label_i64(widened.trunc())
	}

	fun as_u64(self): u64 {
		let widened = self.as_f64();
		label_u64(widened.trunc())
	}

	fun as_f32(self): f32 {
		let widened = self.as_f64();
		label_f32(widened)
	}
}

impl i16 {
	[extern("Math.abs")]
	external fun abs(self): i16;

	[extern("Math.pow")]
	external fun pow(self, exponent: i16): i16;

	[extern("Math.min")]
	external fun min(self, other: i16): i16;

	[extern("Math.max")]
	external fun max(self, other: i16): i16;

	fun rem(self, m: i16): i16 {
		self - self / m * m
	}

	[extern("Number")]
	external fun as_f64(self): f64;

	fun as_i8(self): i8 {
		let widened = self.as_f64();
		label_i8(fold_signed(widened, 256f, 128f))
	}

	fun as_u8(self): u8 {
		let widened = self.as_f64();
		label_u8(fold_unsigned(widened, 256f))
	}

	fun as_i16(self): i16 {
		self
	}

	fun as_u16(self): u16 {
		let widened = self.as_f64();
		label_u16(fold_unsigned(widened, 65536f))
	}

