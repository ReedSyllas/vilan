import std::print;
import std::display::Display;

struct Point {
	x: i32,
	y: i32,
}

// A user type implements `Display` to control its string form.
impl Point with Display {
	fun to_string(self): str {
		i"({self.x}, {self.y})"
	}
}

fun main() {
	let n: i32 = 42;
	print(n.to_string()); // 42
	let x: f64 = 3.5f;
	print(x.to_string()); // 3.5
	print(true.to_string()); // true
	print("hi".to_string()); // hi
	let p = Point { x = 1, y = 2 };
	print(p.to_string()); // (1, 2)
}
