// `macro_std` — the macro world's std (proposal/macro-engine.md §3, §4).
// A `macro fun`'s body is hermetic: it sees nothing of its surrounding module
// and imports ONLY from this package, so this package's surface IS the
// expansion sandbox — `fs`, the clock, `random`, and `[extern]` aren't
// restricted here, they are absent.
//
// Phase 0 ships the compiler-interaction surface (`meta`, `source`). The
// pure-core vocabulary (`Option`, `Result`, `List` methods, `format`, …)
// reaches macro bodies as re-exports of `std`'s pure modules — HOW those
// resolve is the hermetic resolver's job (Phase 1): macro-scope imports
// resolve against this package's universe instead of the program's.

// The reflection surface: `import macro_std::meta::{ Item, TypeExpr, .. }`.
export import pkg::meta;

// The output builders (macro-engine.md §3, the construction API step 2):
// `import macro_std::build::{ impl_of, fun_of, match_of, quote, join }`.
export import pkg::build;

// The pure core, re-exported (macro-engine.md §3): the ordinary vocabulary a
// macro keeps — `import macro_std::option::Option::{ self, Some, None };` and
// friends. Nothing platform-flavored is here, and nothing else is reachable.
export import std::option;
export import std::result;
export import std::display;
export import std::debug;
export import std::compare;
export import std::operators;
export import std::map;
export import std::set;
// `panic` throws — the macro's error channel: a throw surfaces as a spanned
// "failed at expansion time" diagnostic at the invocation.
export import std::io::panic;

use meta::Source;

// Builds generated source. The one constructor every macro ends in.
export fun source(text: str): Source {
	Source { text = text }
}

// Gensym placeholders (macro-engine.md §7): each call yields the next
// `__m<N>` placeholder name. The compiler stamps every placeholder unique per
// splice site, so distinct expansions can never capture each other's
// bindings. Deterministic by construction: the counter restarts each run, so
// identical input yields identical output (the §6 cache stays sound).
mut __fresh_counter = 0;

export fun fresh(): str {
	let ordinal = __fresh_counter;
	__fresh_counter = __fresh_counter + 1;
	i"__m{ordinal}"
}
