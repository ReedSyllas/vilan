// `Set<T>` is the built-in hash set. It holds unique values compared **by
// value** — a struct/enum/tuple element works as long as it derives `Hashable`
// (I1). Each element is turned into a canonical `Hash` via `value.hash()`, which
// keys the underlying native map; the original value is stored alongside so
// `for x in set` yields real `T`s in insertion order.
import pkg::hash::{ Hashable, Hash };
import pkg::native_map::NativeMap;

struct Set<T: Hashable> {
	table: NativeMap<T>,
}

impl Set<type T: Hashable> {
	fun new(): Set<T> {
		// The annotated `let` directs `NativeMap::new()`'s element type; a
		// struct-literal field doesn't direct a generic call (a known gap).
		let table: NativeMap<T> = NativeMap::new();
		Set { table = table }
	}

	fun insert(&mut self, value: T) {
		self.table.insert(value.hash(), value);
	}

	fun contains(self, value: T): bool {
		self.table.contains_key(value.hash())
	}

	fun remove(&mut self, value: T) {
		self.table.remove(value.hash());
	}

	fun len(self): i32 {
		self.table.len()
	}

	fun is_empty(self): bool {
		self.len() == 0
	}

	/// A `List` snapshot of the elements, in insertion order (`for x in set`
	/// iterates these).
	fun values(self): List<T> {
		self.table.values()
	}
}
