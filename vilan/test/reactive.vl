import std::print;
import std::reactive::Signal;

// `std::reactive` — explicit-dependency reactivity. A `Signal` is a writable
// root; `map` builds a `Signal` whose dependency is structural (no
// tracking, no `await` hazard); `sub` runs now and on every change. Writing a
// signal propagates through the derived graph to the subscribers.
fun main() {
	let count = Signal::new(0);
	let doubled = count.map(|n| n * 2);

	// `sub` fires immediately with the current value, then on each change.
	doubled.sub(|n| print(n)); // 0

	count.set(1); // doubled -> 2
	count.set_with(|n| n + 4); // count 5, doubled -> 10
	print(doubled.get()); // 10 (a `get` is a non-reactive sample)

	// A second subscriber, on the root this time.
	count.sub(|n| print(n)); // 5 (current value, now)
	count.set(20); // doubled -> 40 (its sub), then count's sub -> 20
}
