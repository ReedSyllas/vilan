// The service — living next to its resources (tour/platforms.md): SQLite,
// the session table, and password hashing sit in the same module as the
// `[rpc]` bodies that use them. The browser entry imports `NotesClient` from
// here and takes only the generated stub and the contract hash — the bodies
// below are server-colored, and only the server entry reaches them.

import std::reactive::Signal;
import std::db::{ Database, Statement, Row };
import std::option::Option::{ self, Some, None };
import pkg::notes::{ Note, AuthOutcome };

// --- node:crypto bindings for password hashing (sync, fits the dispatch
// path). A candidate for std promotion once proven.

external struct HashBuffer;

impl HashBuffer {
	[extern(method, "toString")]
	external fun to_string_encoded(self, encoding: str): str;
}

[extern("node:crypto", "pbkdf2Sync")]
external fun pbkdf2_sync(password: str, salt: str, iterations: i32, key_length: i32, digest: str): HashBuffer;

[extern("node:crypto", "randomBytes")]
external fun random_bytes_sync(length: i32): HashBuffer;

fun hash_password(password: str, salt: str): str {
	pbkdf2_sync(password, salt, 100000, 64, "sha512").to_string_encoded("hex")
}

fun fresh_token(): str {
	random_bytes_sync(32).to_string_encoded("hex")
}

// --- the service ---

// `[service(NotesClient)]` generates the typed client; `[expose]` mirrors
// the note list to every connected client; each `[rpc]` method is callable
// remotely. The bodies reach the module-level `db` (below) directly by loan —
// no injected hooks. The store holds only the reactive state it exposes: a
// `Database` is a `resource`, so a struct owning one would be a resource too,
// and the generated dispatcher captures the store into its per-`[rpc]` handler
// closures (which a resource cannot be — R9). Process-lifetime state lives at
// module scope; the store stays plain data.
[service(NotesClient)]
struct NotesStore {
	[expose] notes: Signal<List<Note>>,
}

impl NotesStore {
	// Register-or-login in one call: a new username creates the account,
	// a known one checks the password. Returns a session token.
	[rpc]
	fun sign_in(self, username: str, password: str): AuthOutcome {
		if username.len() < 2 || password.len() < 8 {
			ret AuthOutcome { ok = false, token = "", reason = "username or password too short" };
		}
		match db.prepare("SELECT salt, password_hash FROM account WHERE username = ?").first([username]) {
			Some(let row) => {
				if row.text("password_hash") == hash_password(password, row.text("salt")) {
					open_session(db, username)
				} else {
					AuthOutcome { ok = false, token = "", reason = "wrong password" }
				}
			},
			None => {
				let salt = fresh_token();
				db.prepare("INSERT INTO account (username, salt, password_hash) VALUES (?, ?, ?)")
					.run([username, salt, hash_password(password, salt)]);
				open_session(db, username)
			},
		}
	}

	// Creates a note; returns the new id, or -1 when the token is bad.
	// SQL first, then the signal — the signal write is the broadcast, so a
	// crash between the two can never announce state that was never stored.
	[rpc]
	fun add_note(self, token: str, title: str): i32 {
		match session_user(db, token) {
			Some(let _user) => {
				let id = db.prepare("INSERT INTO note (title, body) VALUES (?, ?)").run([title, ""]);
				self.notes.set_with(|list| {
					mut updated = list;
					updated.push(Note { id = id, title = title, body = "" });
					updated
				});
				id
			},
			None => 0 - 1,
		}
	}

	// Renames a note. Title and body commit separately so the editor's
	// per-field drafts never re-send each other's text.
	[rpc]
	fun retitle_note(self, token: str, note_id: i32, title: str): i32 {
		match session_user(db, token) {
			Some(let _user) => {
				db.prepare("UPDATE note SET title = ? WHERE id = ?").run([title, note_id]);
				self.notes.set_with(|list| list.map(|note| {
					if note.id == note_id {
						Note { id = note.id, title = title, body = note.body }
					} else {
						note
					}
				}));
				note_id
			},
			None => 0 - 1,
		}
	}

	// Replaces a note's body.
	[rpc]
	fun rewrite_note(self, token: str, note_id: i32, body: str): i32 {
		match session_user(db, token) {
			Some(let _user) => {
				db.prepare("UPDATE note SET body = ? WHERE id = ?").run([body, note_id]);
				self.notes.set_with(|list| list.map(|note| {
					if note.id == note_id {
						Note { id = note.id, title = note.title, body = body }
					} else {
						note
					}
				}));
				note_id
			},
			None => 0 - 1,
		}
	}

	// Deletes a note; returns the id, or -1.
	[rpc]
	fun delete_note(self, token: str, note_id: i32): i32 {
		match session_user(db, token) {
			Some(let _user) => {
				db.prepare("DELETE FROM note WHERE id = ?").run([note_id]);
				self.notes.set_with(|list| list.filter(|note| note.id != note_id));
				note_id
			},
			None => 0 - 1,
		}
	}
}

// The database is module-level: process lifetime, opened once at startup and
// never dropped (destruction.md §5 — a serve-forever server's `Database` is
// exactly this, the sanctioned home for a long-lived resource). The service and
// its helpers reach it by loan — method calls and `&`-passing — and never move
// it: a module-level resource is loan-only. Its `db.close()` runs only when the
// process ends. Reachability keeps it out of the client bundle (nothing on the
// client entry reaches it), so the browser never imports `node:sqlite`.
let db: Database = open_database();

// Open (or create) the database and ensure its schema — the one place the tables
// are declared. Returns the handle to the module-level binding above.
fun open_database(): Database {
	let database = Database::open("notes.db");
	database.exec("CREATE TABLE IF NOT EXISTS account (id INTEGER PRIMARY KEY, username TEXT UNIQUE, salt TEXT, password_hash TEXT)");
	database.exec("CREATE TABLE IF NOT EXISTS session (token TEXT PRIMARY KEY, username TEXT)");
	database.exec("CREATE TABLE IF NOT EXISTS note (id INTEGER PRIMARY KEY, title TEXT, body TEXT)");
	database
}

// Boot: load the mirror once from the already-open database and hand back the
// store. Every later write goes SQL-first through the methods above.
fun boot(): NotesStore {
	NotesStore {
		notes = Signal::new(load_notes(db)),
	}
}

// The session table is the auth boundary: a token row names its user.
fun session_user(db: Database, token: str): Option<str> {
	match db.prepare("SELECT username FROM session WHERE token = ?").first([token]) {
		Some(let row) => Some(row.text("username")),
		None => None,
	}
}

fun open_session(db: Database, username: str): AuthOutcome {
	let token = fresh_token();
	db.prepare("INSERT INTO session (token, username) VALUES (?, ?)").run([token, username]);
	AuthOutcome { ok = true, token = token, reason = "" }
}

fun load_notes(db: Database): List<Note> {
	mut list: List<Note> = [];
	for row in db.prepare("SELECT id, title, body FROM note ORDER BY id").all([]) {
		list.push(Note { id = row.integer("id"), title = row.text("title"), body = row.text("body") });
	}
	list
}
