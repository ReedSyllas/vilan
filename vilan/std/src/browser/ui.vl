// `std::ui` — a declarative, fine-grained reactive view layer over `std::dom`.
//
// A `View` describes a DOM element; methods chain to build it. Plain setters
// (`text`/`class`/`attr`) set static content; the `bind_*` setters take a
// `Signal` and keep one DOM property in sync — each is an `effect`, so when
// the signal changes only that property updates, with no re-render.
//
// OWNERSHIP LIVES AT DISPOSAL BOUNDARIES (proposal/ambient-owner.md §4): a
// subscription must die exactly when its subtree becomes garbage, and
// subtrees only become garbage at DYNAMIC boundaries — a `mount_root`/`comp`
// root, a `bind_each` row, a `when` instantiation. Static content shares its
// nearest boundary's lifetime, so `View` carries no owner and bindings
// register AMBIENTLY into the nearest boundary. Building UI outside every
// boundary is a COMPILE error (the context coverage fence): every entry
// point establishes a root, so no subscription can be unrooted.
//
// `show` deliberately stays a visibility toggle — content mounted, state
// preserved, no boundary. `when` is the state-dropping form: it mounts its
// body under a fresh owner per instantiation and disposes it on the way out.
//
// Only available when building for the browser (`vilan build --target browser`).

import pkg::dom::{ Element, Event, get_element_by_id, create_element };
import pkg::reactive::{ Signal, Owner, Disposable, reconcile, RowStep, owner_scope, get_owner, run_with_owner, comp, turn_scope, turn, FlushPolicy, Draft };
import pkg::shared::Shared;
import pkg::style::Style;
import pkg::compare::PartialEq;
import pkg::option::Option::{ self, Some, None };

/// A handle to a DOM element under construction — nothing more: ownership is
/// the enclosing boundary's job.
struct View {
	element: Element,
}

/// A fresh element of the given tag (`view("div")`, `view("button")`, …).
fun view(tag: str): View {
	View { element = create_element(tag) }
}

impl View {
	/// Static text content.
	fun text(self, content: str): View {
		self.element.set_text(content);
		self
	}

	/// Static CSS class.
	fun class(self, name: str): View {
		self.element.set_class(name);
		self
	}

	/// Classes from a compiled `Style` (proposal/ui-styling.md §4). Rendering
	/// is runtime-legal — the rules were emitted when the style was
	/// constructed, inside its `const` expression.
	fun styled(self, style: Style): View {
		self.element.set_class(style.class_list());
		self
	}

	/// A signal-driven CSS custom property: pairs with
	/// `width(Length::var("--w"))` in a style — dynamism through the variable,
	/// never through runtime rule construction.
	fun style_var(self, name: str, source: Signal<str>): View {
		let element = self.element;
		let _sub = source.sub(|value| element.set_style_property(name, value));
		self
	}

	/// A static attribute.
	fun attr(self, name: str, value: str): View {
		self.element.set_attribute(name, value);
		self
	}

	/// An event listener (`"click"`, `"input"`, …). A DOM event is a TURN
	/// boundary (proposal/reactive-turns.md §2): the host stores only the
	/// plain adapter below, and each dispatch runs the clause-typed handler
	/// inside a fresh turn — an event's signal writes settle as one wave.
	/// (`AtSuspension` behaves as `AtEnd` until the async hook lands.)
	/// Handlers die with the DOM
	/// node — no registration needed.
	fun on(self, event: str, handler: (|| void) context turn_scope): View {
		self.element.on(event, || turn(FlushPolicy::AtSuspension, || handler()));
		self
	}

	/// Like `on`, but the handler receives the DOM `Event` — for
	/// `prevent_default`, modifier keys, key names. The same turn discipline:
	/// each dispatch settles as one wave.
	fun on_event(self, event: str, handler: (|Event| void) context turn_scope): View {
		self.element.on_event(event, |dispatched| turn(FlushPolicy::AtSuspension, || handler(dispatched)));
		self
	}

	/// Append a child view — structure only, no ownership bookkeeping.
	fun child(self, child: View): View {
		self.element.append(child.element);
		self
	}

	/// Append several child views.
	fun children(self, items: List<View>): View {
		for item in items {
			self.element.append(item.element);
		}
		self
	}

	/// Reactive text content — re-set whenever `source` changes. Registers
	/// with the nearest enclosing boundary (an ambient `effect`).
	fun bind_text(self, source: Signal<str>): View {
		let element = self.element;
		source.effect(|value| {
			element.set_text(value);
		});
		self
	}

	/// Reactive CSS class.
	fun bind_class(self, source: Signal<str>): View {
		let element = self.element;
		source.effect(|value| {
			element.set_class(value);
		});
		self
	}

	/// Reactive attribute.
	fun bind_attr(self, name: str, source: Signal<str>): View {
		let element = self.element;
		source.effect(|value| {
			element.set_attribute(name, value);
		});
		self
	}

	/// Two-way bind an `<input>`'s value to a signal: the input shows the
	/// signal, and typing writes it back.
	fun bind_value(self, signal: Signal<str>): View {
		let element = self.element;
		signal.effect(|value| {
			element.set_value(value);
		});
		// The write-back is a boundary dispatch too: each input event's
		// write settles in its own turn.
		element.on("input", || turn(FlushPolicy::AtSuspension, || {
			signal.set(element.value());
		}));
		self
	}

	/// A local-first editable field: the input shows the draft's local value,
	/// and USER input pushes (locally first, then the draft's commit). An
	/// `adopt`ed remote change writes `local` without passing through here,
	/// so it never re-pushes — and a DIRTY draft ignores adoption entirely,
	/// so an echo never touches a focused input's caret.
	fun bind_draft(self, draft: Draft<str>): View {
		let element = self.element;
		draft.local.effect(|value| {
			// Skip the no-op write (a push echoing through `local`): setting
			// an input's value, even to itself, can move the caret.
			if element.value() != value {
				element.set_value(value);
			}
		});
		element.on("input", || turn(FlushPolicy::AtSuspension, || {
			draft.push(element.value());
		}));
		self
	}

	/// A reactive list, KEYED (backlog A3): one child view per element of
	/// `source`, reconciled by `key` on every change. Each row is a DISPOSAL
	/// BOUNDARY: `render` is an injected closure (proposal/ambient-owner.md
	/// §5) run under the row's own fresh owner, so a row's bindings die with
	/// the row — on refresh, on removal, and when the enclosing boundary goes.
	/// A row whose key survives is reused (its element MOVES into the new
	/// order, subscriptions intact); it re-renders only when its item's value
	/// changed (`T: PartialEq`).
	fun bind_each<T: PartialEq, K: PartialEq>(
		self,
		source: Signal<List<T>>,
		key: sync |T| K,
		render: (sync |T| View) context owner_scope,
	): View {
		let element = self.element;
		let row_keys: Shared<List<K>> = Shared::new([]);
		let row_items: Shared<List<T>> = Shared::new([]);
		let row_views: Shared<List<View>> = Shared::new([]);
		let row_owners: Shared<List<Owner>> = Shared::new([]);
		// Whichever rows are live when the enclosing boundary is disposed go
		// with it.
		get_owner().defer(|| {
			for owner in row_owners.read() {
				owner.dispose();
			}
		});
		source.effect(|list: List<T>| {
			let plan = reconcile(row_keys.read(), row_items.read(), list, key);
			let previous_views = row_views.read();
			let previous_owners = row_owners.read();
			for index in plan.removed {
				previous_owners[index].dispose();
				previous_views[index].element.remove();
			}
			mut next_views: List<View> = [];
			mut next_owners: List<Owner> = [];
			mut position = 0;
			for step in plan.steps {
				let item = list[position];
				match step {
					RowStep::Keep(let index) => {
						next_views.push(previous_views[index]);
						next_owners.push(previous_owners[index]);
					},
					RowStep::Refresh(let index) => {
						previous_owners[index].dispose();
						previous_views[index].element.remove();
						let owner = Owner::new();
						next_views.push(run_with_owner(owner, || render(item)));
						next_owners.push(owner);
					},
					RowStep::Fresh => {
						let owner = Owner::new();
						next_views.push(run_with_owner(owner, || render(item)));
						next_owners.push(owner);
					},
				}
				position += 1;
			}
			// The order pass: append each row in the new order — appending a
			// kept element moves it; a fresh one inserts.
			for row in next_views {
				element.append(row.element);
			}
			mut next_keys: List<K> = [];
			for item in list {
				next_keys.push(key(item));
			}
			row_keys.write() = next_keys;
			row_items.write() = list;
			row_views.write() = next_views;
			row_owners.write() = next_owners;
		});
		self
	}

	/// Conditional CONTENT — the state-dropping boundary: while `condition` is
	/// true the body's view is mounted under a fresh owner; when it turns
	/// false the owner is disposed and the content removed. Toggling back on
	/// re-renders from scratch. (For a state-PRESERVING toggle, use `show`.)
	fun when(self, condition: Signal<bool>, body: (sync || View) context owner_scope): View {
		let element = self.element;
		let live_view: Shared<Option<View>> = Shared::new(None);
		let live_owner: Shared<Option<Owner>> = Shared::new(None);
		// Live content dies with the enclosing boundary.
		get_owner().defer(|| {
			live_owner.read()?.dispose();
		});
		condition.effect(|on| {
			if on {
				match live_view.read() {
					Some(let _present) => {},
					None => {
						let owner = Owner::new();
						let built = run_with_owner(owner, body);
						element.append(built.element);
						live_view.write() = Some(built);
						live_owner.write() = Some(owner);
					},
				}
			} else {
				match live_view.read() {
					Some(let built) => {
						live_owner.read()?.dispose();
						built.element.remove();
						live_view.write() = None;
						live_owner.write() = None;
					},
					None => {},
				}
			}
		});
		self
	}

	/// The dynamic-subtree SWAP (backlog A10) — `when`, generalized from a
	/// toggle to a VALUE: whenever `source` CHANGES, the previous subtree is
	/// disposed (owner and element) and `render` builds the new one under a
	/// fresh owner. `T: PartialEq` makes an equal value a no-op — navigating to
	/// the current route re-renders nothing. Each rendered subtree is a
	/// disposal boundary like a `bind_each` row; whichever is live when the
	/// enclosing boundary goes is disposed with it. Routing is the first
	/// customer (`std::router`): `swap(route, |current| match current { .. })`.
	fun swap<T: PartialEq>(self, source: Signal<T>, render: (sync |T| View) context owner_scope): View {
		let element = self.element;
		let last_value: Shared<Option<T>> = Shared::new(None);
		let live_view: Shared<Option<View>> = Shared::new(None);
		let live_owner: Shared<Option<Owner>> = Shared::new(None);
		// The live subtree dies with the enclosing boundary.
		get_owner().defer(|| {
			live_owner.read()?.dispose();
		});
		source.effect(|value: T| {
			let unchanged = match last_value.read() {
				Some(let previous) => previous == value,
				None => false,
			};
			if !unchanged {
				live_owner.read()?.dispose();
				match live_view.read() {
					Some(let built) => built.element.remove(),
					None => {},
				}
				let owner = Owner::new();
				let built = run_with_owner(owner, || render(value));
				element.append(built.element);
				last_value.write() = Some(value);
				live_view.write() = Some(built);
				live_owner.write() = Some(owner);
			}
		});
		self
	}

	/// Show or hide the element on a reactive condition — present when
	/// `condition` is true, hidden otherwise. A pure visibility toggle: the
	/// content stays mounted and its state (bindings, input text) survives.
	fun show(self, condition: Signal<bool>): View {
		let element = self.element;
		condition.effect(|visible| {
			element.set_hidden(!visible);
		});
		self
	}
}

/// Attach a view to the page element with the given id.
fun mount(id: str, view: View) {
	get_element_by_id(id).append(view.element);
}

/// Mount a component ROOT: the body builds under a fresh ambient owner (the
/// root boundary — every binding inside registers into it) and the view is
/// attached. Returns the root owner; most apps let it live forever.
fun mount_root(id: str, body: (sync || View) context owner_scope): Owner {
	// The initial build is a turn boundary too: bindings created during
	// mount settle as one wave instead of notifying per-`set`.
	let (built, root) = turn(FlushPolicy::AtSuspension, || comp(body));
	mount(id, built);
	root
}
